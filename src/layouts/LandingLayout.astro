---
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: string;
}

const { title, description, lang = 'ru' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />

  <!-- OG Tags -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content={lang === 'ru' ? 'ru_RU' : 'en_US'} />

  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#1B4D5C" />

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "MindHub24",
    "description": description,
    "url": "https://mindhub24.com",
    "serviceType": "Psychological Counseling",
    "areaServed": ["Israel", "Russia", "Poland", "Latvia", "Estonia"],
    "availableLanguage": ["Russian"],
    "priceRange": "€50",
    "openingHours": "Mo-Su 00:00-24:00",
  })} />

  <title>{title}</title>
</head>
<body>
  <!-- Scroll progress bar (1px gold line at top) -->
  <div id="scrollProgress" style="position:fixed;top:0;left:0;right:0;height:1px;background:var(--color-accent);transform-origin:left;transform:scaleX(0);z-index:9999;pointer-events:none;"></div>

  <!-- Ambient effects -->
  <div class="cursor-glow" id="cursorGlow"></div>
  <div class="grain"></div>

  <slot />

  <!-- Night mode detection (runs synchronously before paint) -->
  <script>
    const hour = new Date().getHours();
    const isNight = hour >= 23 || hour < 5;
    if (isNight) {
      document.body.setAttribute('data-night', 'true');
      const dayHero = document.getElementById('dayHero');
      const nightHero = document.getElementById('nightHero');
      if (dayHero) dayHero.style.display = 'none';
      if (nightHero) nightHero.style.display = 'block';
    }
  </script>

  <!-- Core scripts -->
  <script>
    import Lenis from 'lenis';
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // ── Reduced motion check ──────────────────────────────────────────
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── Cursor glow (desktop only) ────────────────────────────────────
    if (window.matchMedia('(hover: hover)').matches) {
      const glow = document.getElementById('cursorGlow');
      let mx = 0, my = 0, gx = 0, gy = 0;
      document.addEventListener('mousemove', (e) => { mx = e.clientX; my = e.clientY; });
      (function moveGlow() {
        gx += (mx - gx) * 0.06;
        gy += (my - gy) * 0.06;
        if (glow) { glow.style.left = gx + 'px'; glow.style.top = gy + 'px'; }
        requestAnimationFrame(moveGlow);
      })();
    }

    // ── Lenis smooth scroll ───────────────────────────────────────────
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    });

    lenis.on('scroll', ScrollTrigger.update);

    gsap.ticker.add((time: number) => {
      lenis.raf(time * 1000);
    });
    gsap.ticker.lagSmoothing(0);

    // ── Scroll progress bar ───────────────────────────────────────────
    const progressBar = document.getElementById('scrollProgress');
    lenis.on('scroll', ({ progress }: { progress: number }) => {
      if (progressBar) progressBar.style.transform = `scaleX(${progress})`;
    });

    // ── Nav scroll class ──────────────────────────────────────────────
    const nav = document.getElementById('mainNav');
    ScrollTrigger.create({
      start: 'top -60px',
      onUpdate: (self) => nav?.classList.toggle('scrolled', self.progress > 0),
    });

    if (prefersReduced) {
      // Instantly show all hidden elements
      document.querySelectorAll('[data-reveal]').forEach((el) => {
        (el as HTMLElement).style.opacity = '1';
        (el as HTMLElement).style.transform = 'none';
      });
    } else {
      // ── HERO ENTRANCE TIMELINE ──────────────────────────────────────
      // Set initial states for hero elements
      gsap.set('#mainNav', { y: '-100%' });
      gsap.set('#heroEyebrow', { opacity: 0, y: 20 });
      gsap.set('.hero-h1-line', { y: '120%' });
      gsap.set('#heroDesc, #heroDescNight', { opacity: 0, y: 30 });
      gsap.set('#heroButtons > *', { opacity: 0, y: 20 });
      gsap.set('#heroImageWrapper', { opacity: 0, scale: 1.04 });
      gsap.set('#heroFloat', { opacity: 0, y: 20 });

      const heroTL = gsap.timeline();
      heroTL
        .to('#mainNav',            { y: 0,       duration: 0.8, ease: 'power3.out' },  0.2)
        .to('#heroEyebrow',        { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, 0.5)
        .to('.hero-h1-line',       { y: 0,       duration: 1.0, ease: 'expo.out', stagger: 0.12 }, 0.6)
        .to('#heroDesc, #heroDescNight', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, 1.0)
        .to('#heroButtons > *',    { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out', stagger: 0.1 }, 1.2)
        .to('#heroImageWrapper',   { opacity: 1, scale: 1, duration: 1.4, ease: 'expo.out' },  0.4)
        .to('#heroFloat',          { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' },  1.6);

      // ── HERO IMAGE PARALLAX ─────────────────────────────────────────
      const heroImg = document.getElementById('heroImg');
      if (heroImg) {
        gsap.to(heroImg, {
          y: 50,
          ease: 'none',
          scrollTrigger: {
            trigger: '#heroImageWrapper',
            start: 'top top',
            end: 'bottom top',
            scrub: 1.5,
          },
        });
      }

      // ── GENERIC SCROLL REVEALS for [data-reveal] ───────────────────
      document.querySelectorAll('[data-reveal]').forEach((el) => {
        gsap.fromTo(el,
          { opacity: 0, y: 40 },
          {
            opacity: 1, y: 0,
            duration: 0.9,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 87%',
              once: true,
            },
          }
        );
      });

      // ── SECTION LABELS ──────────────────────────────────────────────
      document.querySelectorAll('.s-label').forEach((el) => {
        if ((el as HTMLElement).dataset.reveal !== undefined) return; // already handled
        gsap.fromTo(el,
          { opacity: 0, y: 20 },
          { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 87%', once: true } }
        );
      });

      // ── SECTION TITLES ──────────────────────────────────────────────
      document.querySelectorAll('.s-title').forEach((el) => {
        if ((el as HTMLElement).dataset.reveal !== undefined) return;
        gsap.fromTo(el,
          { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.85, ease: 'power3.out', delay: 0.1,
            scrollTrigger: { trigger: el, start: 'top 87%', once: true } }
        );
      });

      // ── PAIN CARDS (stagger) ────────────────────────────────────────
      const painCards = document.querySelectorAll('[data-pain-card]');
      if (painCards.length) {
        gsap.fromTo(painCards,
          { opacity: 0, y: 60 },
          { opacity: 1, y: 0, duration: 1.0, ease: 'expo.out', stagger: 0.15,
            scrollTrigger: { trigger: painCards[0].parentElement, start: 'top 80%', once: true } }
        );
      }

      // ── STEP CARDS (stagger + 3D tilt) ─────────────────────────────
      const stepCards = document.querySelectorAll('[data-step-card]');
      if (stepCards.length) {
        gsap.set(stepCards, { transformPerspective: 800 });
        gsap.fromTo(stepCards,
          { opacity: 0, y: 80, rotateX: 5 },
          { opacity: 1, y: 0, rotateX: 0, duration: 1.0, ease: 'expo.out', stagger: 0.2,
            transformOrigin: 'top center',
            scrollTrigger: { trigger: stepCards[0].parentElement, start: 'top 80%', once: true } }
        );
      }

      // ── SERVICE CARDS (stagger + scale) ─────────────────────────────
      const serviceCards = document.querySelectorAll('[data-service-card]');
      if (serviceCards.length) {
        gsap.fromTo(serviceCards,
          { opacity: 0, scale: 0.9 },
          { opacity: 1, scale: 1, duration: 0.8, ease: 'expo.out', stagger: 0.1,
            scrollTrigger: { trigger: serviceCards[0].parentElement, start: 'top 80%', once: true } }
        );
      }

      // ── PHRASE PILLS (back.out bounce) ──────────────────────────────
      const pills = document.querySelectorAll('[data-phrase-pill]');
      if (pills.length) {
        gsap.fromTo(pills,
          { opacity: 0, scale: 0.8 },
          { opacity: 1, scale: 1, duration: 0.6, ease: 'back.out(1.7)', stagger: 0.06,
            scrollTrigger: { trigger: pills[0].parentElement, start: 'top 82%', once: true } }
        );
      }

      // ── VOICE CARDS (stagger) ────────────────────────────────────────
      const voiceCards = document.querySelectorAll('[data-voice-card]');
      if (voiceCards.length) {
        gsap.fromTo(voiceCards,
          { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 1.0, ease: 'expo.out', stagger: 0.12,
            scrollTrigger: { trigger: voiceCards[0].parentElement, start: 'top 82%', once: true } }
        );
      }

      // ── ABOUT PHOTO (parallax + reveal) ─────────────────────────────
      const aboutPhoto = document.querySelector('[data-about-photo]');
      if (aboutPhoto) {
        const imgEl = aboutPhoto.querySelector('img');
        if (imgEl) {
          // Reveal: image scales from 1.1 → 1 inside overflow:hidden
          gsap.fromTo(imgEl,
            { scale: 1.1 },
            { scale: 1, duration: 1.4, ease: 'expo.out',
              scrollTrigger: { trigger: aboutPhoto, start: 'top 80%', once: true } }
          );
          // Parallax: subtle upward drift
          gsap.to(imgEl, {
            y: -50,
            ease: 'none',
            scrollTrigger: {
              trigger: aboutPhoto,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1.5,
            },
          });
        }
      }

      ScrollTrigger.refresh();
    }
  </script>
</body>
</html>
