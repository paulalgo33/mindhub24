---
/**
 * MindHub24 — Russia Landing Page
 * Price in ₽, Google Ads destination
 * No Meta/Instagram references (blocked in Russia)
 * Prodamus payment integration
 */
import LandingLayout from '@/layouts/LandingLayout.astro';
import Nav from '@/components/Nav.astro';
import Hero from '@/components/Hero.astro';
import Marquee from '@/components/Marquee.astro';
import Quiz from '@/components/Quiz.astro';
import Voices from '@/components/Voices.astro';
import Footer from '@/components/Footer.astro';
import AudioPlayer from '@/components/AudioPlayer.astro';
import { ru } from '@/i18n/ru';

// Override pricing for Russia
const t = {
  ...ru,
  meta: {
    title: 'MindHub24 — Психолог онлайн',
    description: 'Профессиональное психологическое консультирование онлайн. Конфиденциально. Первая встреча бесплатно. 5 000 ₽ за сессию.',
  },
  pricing: {
    ...ru.pricing,
    cards: [
      { type: 'Знакомство', amount: 'Бесплатно', desc: '20 минут · Видеозвонок\nБез обязательств', cta: 'Записаться' },
      { type: 'Консультация', amount: '5 000 ₽', desc: '50 минут · Видеозвонок\nСтруктурированная работа', cta: 'Записаться', featured: true },
    ],
    compare: 'Конкурентная стоимость для Москвы и Санкт-Петербурга.',
  },
  crisis: {
    title: 'Если вы в кризисной ситуации:',
    lines: [
      'Россия: 8-800-2000-122 (бесплатно)',
      'Телефон доверия: 8-495-988-44-34',
      'Экстренная помощь: 112',
    ],
    disclaimer: 'MindHub24 не является экстренной службой.',
  },
};

// SVG icon set — stroke="currentColor", 22×22, minimal
const serviceIcons = [
  // Тревога — brain with pulse line
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21v-2a5 5 0 0 1-4-5c0-1.5.6-2.8 1.5-3.8A4 4 0 0 1 9 3a3 3 0 0 1 3 2.3A3 3 0 0 1 15 3a4 4 0 0 1 2.5 7.2A5 5 0 0 1 19 14a5 5 0 0 1-4 5v2"/><polyline points="7.5,14 9,11 10.5,14.5 12,11 13.5,14.5 15.5,11 17,14"/></svg>`,
  // Адаптация к переезду — globe with pin
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="15" r="6"/><path d="M11 9a6 6 0 0 1 0 12"/><path d="M11 9a6 6 0 0 0 0 12"/><line x1="5" y1="15" x2="17" y2="15"/><path d="M15 5.5c0 2.2-3 5.5-3 5.5S9 7.7 9 5.5a3 3 0 0 1 6 0z"/></svg>`,
  // Отношения — two overlapping circles
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8.5" cy="12" r="5.5"/><circle cx="15.5" cy="12" r="5.5"/></svg>`,
  // Выгорание — battery with low charge
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="8" width="16" height="8" rx="2"/><path d="M20 11v2" stroke-width="2"/><rect x="4" y="10.5" width="3.5" height="3" rx="0.5" fill="currentColor" stroke="none"/></svg>`,
  // Жизненные кризисы — compass
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polygon points="12,6 13.5,11 12,10 10.5,11" fill="currentColor" stroke="none"/><polygon points="12,18 10.5,13 12,14 13.5,13" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="1.2" fill="currentColor" stroke="none"/></svg>`,
  // Самооценка — mirror
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="9" rx="5.5" ry="6.5"/><line x1="12" y1="15.5" x2="12" y2="19"/><line x1="9" y1="19" x2="15" y2="19"/></svg>`,
];
---

<LandingLayout title={t.meta.title} description={t.meta.description} lang="ru">

<Nav cta={t.nav.cta} lang="ru" />

<Hero t={t} />

<Marquee items={t.marquee} />

<!-- Pain section -->
<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-cream)]">
  <div class="max-w-[1000px] mx-auto">
    <p class="s-label" data-reveal>{t.pain.label}</p>
    <h2 class="s-title" data-reveal="d1">{t.pain.title} <em>{t.pain.titleEm}</em></h2>
    <p class="s-subtitle" data-reveal="d2">{t.pain.subtitle}</p>
    <div class="pain-grid grid grid-cols-1 md:grid-cols-2 gap-5 mb-12">
      {t.pain.cards.map((card) => (
        <div class="p-8 pl-9 bg-white rounded-2xl border border-[var(--color-border)] border-l-[3px] text-[1.05rem] leading-[1.75] font-light card-glass" data-pain-card>{card}</div>
      ))}
    </div>
    <p class="font-heading text-xl italic text-[var(--color-text-mid)] leading-relaxed max-w-[600px]" data-reveal>{t.pain.closing}</p>
  </div>
</section>

<!-- Steps -->
<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-warm)]">
  <div class="max-w-[1200px] mx-auto">
    <p class="s-label" data-reveal>{t.steps.label}</p>
    <h2 class="s-title" data-reveal="d1">{t.steps.title}</h2>
    <p class="s-subtitle" data-reveal="d2">{t.steps.subtitle}</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-10">
      {t.steps.items.map((step) => (
        <div class="p-10 rounded-[20px] border border-[var(--color-border)] bg-white card-glass" data-step-card>
          <div class="font-heading text-6xl font-bold leading-none bg-gradient-to-b from-[rgba(15,46,56,0.08)] to-[rgba(15,46,56,0.02)] bg-clip-text text-transparent mb-6">{step.num}</div>
          <h3 class="font-heading text-xl font-semibold mb-3">{step.title}</h3>
          <p class="text-base text-[var(--color-text-mid)] font-light leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Services -->
<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] text-white relative overflow-hidden" style="background:linear-gradient(160deg,#0a1f28 0%,#0F2E38 100%);">
  <div class="services-aurora-a"></div>
  <div class="services-aurora-b"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[rgba(201,168,76,0.4)] to-transparent"></div>
  <div class="max-w-[1200px] mx-auto relative z-2">
    <p class="s-label text-[var(--color-accent-light)]" data-reveal>{t.services.label}</p>
    <h2 class="font-heading text-[clamp(2rem,4vw,3rem)] font-normal leading-snug text-white tracking-[-0.02em] mb-5" data-reveal="d1">{t.services.title}</h2>
    <p class="text-lg text-white/50 font-light leading-relaxed mb-14 max-w-[600px]" data-reveal="d2">{t.services.subtitle}</p>
    <div class="services-grid grid grid-cols-1 md:grid-cols-3 gap-5">
      {t.services.items.map((srv, i) => (
        <div class="p-9 rounded-[18px] bg-white/[0.04] border border-white/[0.06] hover:bg-white/[0.08] hover:border-[rgba(201,168,76,0.2)] hover:-translate-y-1 transition-all duration-500" data-service-card>
          <div class="service-icon w-12 h-12 flex items-center justify-center bg-white/[0.07] rounded-[14px] mb-5 transition-all duration-400" set:html={serviceIcons[i]} />
          <h3 class="font-heading text-lg font-semibold mb-2 text-white">{srv.name}</h3>
          <p class="text-sm text-white/50 font-light leading-relaxed">{srv.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Approach -->
<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-warm)]">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-[clamp(3rem,6vw,6rem)] items-center">
    <div>
      <p class="s-label" data-reveal>{t.approach.label}</p>
      <h2 class="s-title" data-reveal="d1">{t.approach.title}</h2>
      <div class="flex flex-col gap-6 mb-10">
        {t.approach.items.map((item, i) => (
          <div class="flex items-start gap-5 text-lg leading-[1.65] font-light" data-reveal={`d${Math.min(i+1,4)}`}>
            <span class="shrink-0 w-5 h-0.5 bg-[var(--color-primary)] mt-3"></span>{item}
          </div>
        ))}
      </div>
      <div class="font-heading text-xl italic text-[var(--color-primary)] leading-relaxed p-7 bg-[rgba(27,77,92,0.04)] rounded-2xl border border-[rgba(27,77,92,0.08)]" data-reveal="d4">{t.approach.quote}</div>
    </div>
    <div class="rounded-[20px] overflow-hidden aspect-[4/5] shadow-[0_30px_60px_rgba(0,0,0,0.06)] hide-mobile">
      <img
        src="/images/alexandra-session.jpeg"
        alt="MindHub24 подход"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  </div>
</section>

<AudioPlayer label={t.audio.label} title={t.audio.title} subtitle={t.audio.subtitle} playerTitle={t.audio.playerTitle} playerMeta={t.audio.playerMeta} hint={t.audio.hint} />

<!-- Phrases -->
<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-warm)]">
  <div class="max-w-[800px] mx-auto text-center">
    <p class="s-label" data-reveal>{t.phrases.label}</p>
    <h2 class="s-title text-center" data-reveal="d1">{t.phrases.title}</h2>
    <p class="s-subtitle text-center mx-auto max-w-[500px]" data-reveal="d2">{t.phrases.subtitle}</p>
    <div class="flex flex-wrap gap-3 justify-center my-10">
      {t.phrases.items.map((phrase) => (
        <span class="py-3.5 px-6 bg-white border border-[var(--color-border)] rounded-full text-base text-[var(--color-text-mid)] font-light italic cursor-default hover:bg-[var(--color-deep)] hover:text-white hover:border-[var(--color-deep)]" data-phrase-pill>{phrase}</span>
      ))}
    </div>
    <p class="font-heading text-xl text-[var(--color-primary)] font-medium" data-reveal>{t.phrases.closing}</p>
  </div>
</section>

<Quiz label={t.quiz.label} title={t.quiz.title} subtitle={t.quiz.subtitle} cta={t.quiz.cta} fine={t.quiz.fine} questions={t.quiz.questions} result={t.quiz.result} resultCta={t.quiz.resultCta} />

<!-- About -->
<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-warm)]">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr] gap-[clamp(3rem,6vw,6rem)] items-center">
    <div data-about-photo class="rounded-3xl overflow-hidden aspect-[3/4] shadow-[0_40px_80px_rgba(0,0,0,0.07)]">
      <img
        src="/images/alexandra-about.jpeg"
        alt="Александра — MindHub24"
        class="w-full h-full object-cover"
        loading="lazy"
        style="will-change:transform;"
      />
    </div>
    <div>
      <p class="s-label" data-reveal>{t.about.label}</p>
      <h2 class="font-heading text-4xl font-medium text-[var(--color-deep)] tracking-[-0.02em] mb-2" data-reveal="d1">{t.about.name}</h2>
      <p class="text-sm text-[var(--color-text-mid)] font-normal mb-8" data-reveal="d2">{t.about.role}</p>
      {t.about.text.map((p, i) => (
        <p class="text-lg leading-[1.85] text-[var(--color-text-mid)] font-light mb-5" data-reveal={`d${i+2}`}>{p}</p>
      ))}
      <div class="flex flex-wrap gap-2.5 mt-8" data-reveal="d4">
        {t.about.tags.map((tag) => (
          <span class="py-2 px-4 bg-[rgba(15,46,56,0.05)] rounded-full text-xs text-[var(--color-primary)] font-medium">{tag}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Pricing -->
<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-cream)]" id="pricing">
  <div class="max-w-[800px] mx-auto text-center">
    <p class="s-label" data-reveal>{t.pricing.label}</p>
    <h2 class="s-title text-center" data-reveal="d1">{t.pricing.title}</h2>
    <div class="pricing-grid grid grid-cols-1 md:grid-cols-2 gap-6 mt-10">
      {t.pricing.cards.map((card, i) => (
        <div class:list={["p-10 rounded-3xl text-center price-card card-glass", card.featured ? "border-2 border-[var(--color-deep)] bg-[rgba(27,77,92,0.03)] relative" : "bg-white border border-[var(--color-border)]"]} data-reveal={`d${i+1}`}>
          {card.featured && <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[var(--color-deep)] text-white text-[0.7rem] tracking-[0.08em] uppercase py-1 px-4 rounded-full font-medium">Популярный выбор</span>}
          <div class="text-xs tracking-[0.12em] uppercase text-[var(--color-text-light)] font-semibold mb-5">{card.type}</div>
          <div class="font-heading text-[clamp(3rem,8vw,4rem)] font-semibold text-[var(--color-deep)] mb-1.5 leading-none">{card.amount}</div>
          <div class="text-sm text-[var(--color-text-mid)] font-light leading-relaxed whitespace-pre-line mt-2">{card.desc}</div>
          <button class="btn-primary mt-6"><span>{card.cta}</span></button>
        </div>
      ))}
    </div>
    <p class="mt-8 text-base text-[var(--color-text-mid)] font-light" data-reveal>{t.pricing.note}</p>
    <p class="text-sm text-[var(--color-accent)] font-normal mt-2" data-reveal>{t.pricing.compare}</p>
  </div>
</section>

<Voices label={t.voices.label} title={t.voices.title} items={t.voices.items} closing={t.voices.closing} />

<!-- Final CTA -->
<section class="py-[var(--spacing-section-lg)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-cream)] text-center relative overflow-hidden">
  <div class="absolute w-[600px] h-[600px] rounded-full blur-[120px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-[radial-gradient(circle,rgba(27,77,92,0.06),transparent_70%)] pointer-events-none"></div>
  <div class="relative z-2 max-w-[600px] mx-auto">
    <h2 class="font-heading text-[clamp(2.8rem,6vw,4.5rem)] font-medium text-[var(--color-deep)] mb-4 leading-[1.08] tracking-[-0.03em]" data-reveal>{t.final.title}</h2>
    <p class="text-lg text-[var(--color-text-mid)] font-light mb-10 whitespace-pre-line" data-reveal="d1">{t.final.subtitle}</p>
    <a href="#pricing" class="btn-primary text-lg py-5 px-10" data-reveal="d2">
      <span>{t.final.cta}</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
    <p class="text-sm text-[var(--color-text-light)] mt-4 font-light" data-reveal="d3">{t.final.micro}</p>
  </div>
</section>

<Footer t={t} />

</LandingLayout>
