---
/**
 * MindHub24 — Free Consultation Landing Page
 * Generic LP, no country-specific content
 * Title: "Бесплатная онлайн-консультация с психологом — MindHub24"
 */
import LandingLayout from '@/layouts/LandingLayout.astro';
import Nav from '@/components/Nav.astro';
import Marquee from '@/components/Marquee.astro';
import Quiz from '@/components/Quiz.astro';
import Voices from '@/components/Voices.astro';
import BreathingCircle from '@/components/BreathingCircle.astro';
import { ru } from '@/i18n/ru';

const t = {
  ...ru,
  meta: {
    title: 'Бесплатная онлайн-консультация с психологом — MindHub24',
    description: 'Запишитесь на бесплатную онлайн-встречу с психологом. 15 минут. Без обязательств. Первый шаг — бесплатно.',
  },
  crisis: {
    title: 'Если вы в кризисной ситуации:',
    lines: [
      'Европа: 112',
      'Россия: 8-800-2000-122',
    ],
    disclaimer: 'MindHub24 не является экстренной службой.',
  },
};
---

<LandingLayout title={t.meta.title} description={t.meta.description} lang="ru">

<Nav cta={t.nav.cta} lang="ru" />

<BreathingCircle />

<!-- HERO — conversion-focused, no country specifics -->
<section class="pt-[130px] pb-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-cream)] relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(27,77,92,0.04),transparent_60%)] pointer-events-none"></div>
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-2">
    <div>
      <p class="text-[0.65rem] tracking-[0.18em] uppercase text-[var(--color-accent)] font-semibold mb-5" data-reveal>Психологическое консультирование · Онлайн</p>
      <h1 class="font-heading text-[clamp(2.8rem,5.5vw,4rem)] font-normal leading-[1.1] tracking-[-0.03em] text-[var(--color-deep)] mb-6" data-reveal>
        Бесплатная онлайн-встреча с психологом. <em>15 минут.</em>
      </h1>
      <p class="text-lg text-[var(--color-text-mid)] font-light leading-[1.85] mb-8 max-w-[500px]" data-reveal>
        Расскажите, что происходит. Мы поможем разобраться. Без обязательств.
      </p>
      <div class="flex flex-wrap gap-4 mb-8" data-reveal>
        <a href="/book/" class="btn-primary text-base py-4 px-8">
          <span>Записаться бесплатно</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="flex flex-wrap gap-3 mt-6" data-reveal>
        <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 backdrop-blur-sm border border-[var(--color-border)] shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          <span class="text-sm font-medium text-[var(--color-deep)]">Конфиденциально</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 backdrop-blur-sm border border-[var(--color-border)] shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          <span class="text-sm font-medium text-[var(--color-deep)]">Из любой страны</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 backdrop-blur-sm border border-[var(--color-border)] shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12v6a2 2 0 01-2 2H6a2 2 0 01-2-2v-6"/><polyline points="12 3 12 15"/><path d="M8 8l4-5 4 5"/></svg>
          <span class="text-sm font-medium text-[var(--color-deep)]">Первая встреча бесплатно</span>
        </div>
      </div>

      <!-- Trust numbers -->
      <div class="flex gap-8 mt-10 flex-wrap" data-reveal>
        {[
          { num: '7+', label: 'лет опыта' },
          { num: '€0', label: 'первая встреча' },
          { num: '100%', label: 'конфиденциально' },
        ].map((item) => (
          <div>
            <div class="font-heading text-3xl font-semibold text-[var(--color-deep)]">{item.num}</div>
            <div class="text-xs text-[var(--color-text-light)] mt-1">{item.label}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="rounded-3xl overflow-hidden aspect-[4/5] shadow-[0_40px_80px_rgba(0,0,0,0.08)] relative" data-reveal>
      <img src="/images/alexandra-greenery.png" alt="Александра — психолог-консультант MindHub24" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 border border-black/[0.03] rounded-3xl"></div>
    </div>
  </div>
</section>

<Marquee items={t.marquee} />

<!-- PAIN RECOGNITION -->
<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-warm)]">
  <div class="max-w-[1000px] mx-auto">
    <p class="s-label text-center" data-reveal>Узнаёте себя?</p>
    <h2 class="s-title text-center" data-reveal>Вы здесь, потому что...</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-10 mb-10">
      {[
        'Тревога стала постоянным фоном — днём и ночью.',
        'Что-то изменилось, но вы ещё не поняли что.',
        'Рядом некому выговориться по-настоящему — на родном языке.',
        'Вы держитесь каждый день. Но устали держаться.',
      ].map((card) => (
        <div class="p-8 pl-9 bg-white rounded-2xl border border-[var(--color-border)] border-l-[3px] card-glass text-[1.05rem] leading-[1.75] font-light text-[var(--color-text)]" data-pain-card>
          {card}
        </div>
      ))}
    </div>
    <p class="font-heading text-xl italic text-[var(--color-text-mid)] leading-relaxed max-w-[600px]" data-reveal>
      Если вы узнали себя — значит, пора поговорить. На своём языке.
    </p>
  </div>
</section>

<!-- STEPS -->
<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-cream)]">
  <div class="max-w-[1200px] mx-auto">
    <p class="s-label" data-reveal>{t.steps.label}</p>
    <h2 class="s-title" data-reveal>{t.steps.title}</h2>
    <p class="s-subtitle" data-reveal>{t.steps.subtitle}</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-10">
      {t.steps.items.map((step) => (
        <div class="p-10 rounded-[20px] border border-[var(--color-border)] bg-white card-glass" data-step-card>
          <div class="font-heading text-6xl font-bold leading-none bg-gradient-to-b from-[rgba(15,46,56,0.08)] to-[rgba(15,46,56,0.02)] bg-clip-text text-transparent mb-6">{step.num}</div>
          <h3 class="font-heading text-xl font-semibold mb-3">{step.title}</h3>
          <p class="text-base text-[var(--color-text-mid)] font-light leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ABOUT + BOOKING CTA -->
<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-warm)]">
  <div class="max-w-[1100px] mx-auto grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr] gap-[clamp(3rem,6vw,6rem)] items-center">
    <div data-about-photo class="rounded-3xl overflow-hidden aspect-[3/4] shadow-[0_40px_80px_rgba(0,0,0,0.07)] relative">
      <img src="/images/alexandra-greenery.png" alt="Александра — психолог MindHub24" class="w-full h-full object-cover" loading="lazy" style="will-change:transform;" />
      <div class="absolute inset-0 border border-black/[0.03] rounded-3xl"></div>
    </div>
    <div>
      <p class="s-label" data-reveal>О специалисте</p>
      <h2 class="font-heading text-4xl font-medium text-[var(--color-deep)] tracking-[-0.02em] mb-2" data-reveal>Александра</h2>
      <p class="text-sm text-[var(--color-text-mid)] font-normal mb-8" data-reveal>Психолог-консультант · Основатель MindHub24</p>
      <p class="text-lg text-[var(--color-text-mid)] font-light leading-[1.85] mb-5" data-reveal>
        Я работаю с тревогой, сложностями в отношениях, кризисными периодами жизни и адаптацией к переезду.
      </p>
      <p class="text-lg text-[var(--color-text-mid)] font-light leading-[1.85] mb-8" data-reveal>
        Работаю с русскоязычными людьми по всему миру. Понимаю, каково это — искать поддержку вдали от дома.
      </p>
      <div class="flex flex-wrap gap-2.5 mb-8" data-reveal>
        {['Онлайн', 'На русском', 'Конфиденциально', 'Первая встреча бесплатно'].map((tag) => (
          <span class="py-2 px-4 bg-[rgba(15,46,56,0.05)] rounded-full text-xs text-[var(--color-primary)] font-medium">{tag}</span>
        ))}
      </div>
      <a href="/book/" class="btn-primary" data-reveal>
        <span>Записаться на бесплатный онлайн-звонок</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<Quiz label={t.quiz.label} title={t.quiz.title} subtitle={t.quiz.subtitle} cta={t.quiz.cta} fine={t.quiz.fine} questions={t.quiz.questions} result={t.quiz.result} resultCta={t.quiz.resultCta} />

<Voices label={t.voices.label} title={t.voices.title} items={t.voices.items} closing={t.voices.closing} />

<!-- Chat bubbles -->
<section class="py-12 px-4" style="background: linear-gradient(180deg, #E8F0ED 0%, #D9E8E2 100%);">
  <div class="max-w-md mx-auto space-y-4">
    <div class="flex justify-start">
      <div class="max-w-xs px-5 py-3 rounded-2xl rounded-bl-md shadow-sm" style="background: white;">
        <p class="text-base" style="color: var(--color-deep);">Вы не будете знать, что сказать. И это нормально.</p>
      </div>
    </div>
    <div class="flex justify-end">
      <div class="max-w-xs px-5 py-3 rounded-2xl rounded-br-md shadow-sm" style="background: var(--color-primary); color: white;">
        <p class="text-base">Не нужно быть в кризисе, чтобы прийти.</p>
      </div>
    </div>
    <div class="flex justify-start">
      <div class="max-w-xs px-5 py-3 rounded-2xl rounded-bl-md shadow-sm" style="background: white;">
        <p class="text-base" style="color: var(--color-deep);">Через 15 минут вы будете рады, что решились.</p>
      </div>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="py-[var(--spacing-section-lg)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-cream)] text-center relative overflow-hidden" id="cta">
  <div class="absolute w-[600px] h-[600px] rounded-full blur-[120px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-[radial-gradient(circle,rgba(27,77,92,0.06),transparent_70%)] pointer-events-none"></div>
  <div class="relative z-2 max-w-[600px] mx-auto">
    <h2 class="font-heading text-[clamp(2.8rem,6vw,4.5rem)] font-medium text-[var(--color-deep)] mb-4 leading-[1.08] tracking-[-0.03em]" data-reveal>
      Бесплатная онлайн-встреча. 15 минут.
    </h2>
    <p class="text-lg text-[var(--color-text-mid)] font-light mb-10" data-reveal>
      Расскажите, что происходит. Мы поможем разобраться. Без обязательств.
    </p>
    <a href="/book/" class="btn-primary text-lg py-5 px-10" data-reveal>
      <span>Записаться бесплатно</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
    </a>
    <p class="text-sm text-[var(--color-text-light)] mt-4 font-light" data-reveal>Конфиденциально · Онлайн · На русском</p>
  </div>
</section>

<!-- Crisis footer -->
<div class="py-8 px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-warm)] text-center border-t border-[var(--color-border)]">
  <p class="text-sm text-[var(--color-text-mid)] font-light max-w-[600px] mx-auto leading-relaxed">
    <strong class="font-medium text-[var(--color-text)]">{t.crisis.title}</strong><br />
    {t.crisis.lines.join(' · ')}<br />
    {t.crisis.disclaimer}
  </p>
</div>

<!-- Footer -->
<footer class="py-14 px-[clamp(1.5rem,4vw,3rem)] bg-[#111] text-center">
  <div class="font-heading text-xl font-semibold text-white/70 mb-5">
    MindHub24<span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] inline-block ml-0.5 mb-0.5"></span>
  </div>
  <div class="flex justify-center gap-8 mb-6 flex-wrap">
    <a href="/privacy/" class="text-xs text-white/30 no-underline font-light transition-colors duration-200 hover:text-white/70">Конфиденциальность</a>
    <a href="/terms/" class="text-xs text-white/30 no-underline font-light transition-colors duration-200 hover:text-white/70">Условия</a>
    <a href="/disclaimer/" class="text-xs text-white/30 no-underline font-light transition-colors duration-200 hover:text-white/70">Отказ от ответственности</a>
    <a href="/cancellation/" class="text-xs text-white/30 no-underline font-light transition-colors duration-200 hover:text-white/70">Отмена</a>
    <a href="/cookies/" class="text-xs text-white/30 no-underline font-light transition-colors duration-200 hover:text-white/70">Куки</a>
  </div>
  <p class="text-[0.72rem] text-white/15 font-light">{t.footer.copy}</p>
</footer>

</LandingLayout>
