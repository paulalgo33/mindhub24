---
import ToolLayout from '@/layouts/ToolLayout.astro';
---

<ToolLayout title="Экстренная помощь" dark={true}>
  <div class="max-w-[580px] mx-auto text-center" style="color:#e6edf3;">

    <div class="mb-10">
      <div class="text-5xl mb-5">🆘</div>
      <h1 class="font-heading text-[clamp(2rem,5vw,2.8rem)] font-normal leading-[1.1] tracking-[-0.03em] mb-4" style="color:#e6edf3;">
        Вам сейчас очень тяжело?
      </h1>
      <p style="color:rgba(230,237,243,0.65);font-weight:300;line-height:1.7;font-size:1.05rem;">
        Пожалуйста, позвоните. Прямо сейчас. Вы заслуживаете помощи — и она есть.
      </p>
    </div>

    <!-- Crisis lines -->
    <div class="flex flex-col gap-4 mb-10">
      <a href="tel:1201" class="crisis-card p-6 rounded-2xl text-left no-underline transition-all duration-300 hover:-translate-y-0.5" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs tracking-[0.1em] uppercase font-semibold mb-1" style="color:rgba(230,237,243,0.45);">Израиль · Телефон доверия</p>
            <p class="font-heading text-2xl font-medium" style="color:#e6edf3;">Eran — 1201</p>
          </div>
          <span class="text-2xl">🇮🇱</span>
        </div>
        <p class="text-xs mt-2" style="color:rgba(230,237,243,0.4);">Круглосуточно · Бесплатно · На иврите и русском</p>
      </a>

      <a href="tel:88002000122" class="crisis-card p-6 rounded-2xl text-left no-underline transition-all duration-300 hover:-translate-y-0.5" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs tracking-[0.1em] uppercase font-semibold mb-1" style="color:rgba(230,237,243,0.45);">Россия · Телефон доверия</p>
            <p class="font-heading text-2xl font-medium" style="color:#e6edf3;">8-800-2000-122</p>
          </div>
          <span class="text-2xl">🇷🇺</span>
        </div>
        <p class="text-xs mt-2" style="color:rgba(230,237,243,0.4);">Круглосуточно · Бесплатно</p>
      </a>

      <a href="tel:112" class="crisis-card p-6 rounded-2xl text-left no-underline transition-all duration-300 hover:-translate-y-0.5" style="background:rgba(201,168,76,0.15);border:1px solid rgba(201,168,76,0.3);">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs tracking-[0.1em] uppercase font-semibold mb-1" style="color:rgba(201,168,76,0.7);">Экстренная служба</p>
            <p class="font-heading text-2xl font-medium" style="color:#e6edf3;">112</p>
          </div>
          <span class="text-2xl">🆘</span>
        </div>
        <p class="text-xs mt-2" style="color:rgba(230,237,243,0.4);">Международный номер экстренной помощи</p>
      </a>
    </div>

    <!-- Reassurance -->
    <div class="p-6 rounded-2xl text-left mb-8" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);">
      <p class="font-heading text-lg italic leading-[1.8]" style="color:rgba(230,237,243,0.85);">
        «Попросить о помощи — это не слабость. Это смелость. И это самое важное, что вы можете сделать прямо сейчас.»
      </p>
    </div>

    <div class="flex flex-col gap-3">
      <a href="/tools/breathe" class="btn-primary w-full justify-center" style="background:rgba(42,122,145,0.6);">
        <span>Дыхательное упражнение прямо сейчас</span>
      </a>
      <a href="/tools/ground" class="btn-ghost w-full justify-center" style="color:rgba(230,237,243,0.5);">
        Техника заземления 5-4-3-2-1
      </a>
      <a href="/tools" class="text-sm" style="color:rgba(230,237,243,0.3);">← Все инструменты</a>
    </div>

  </div>
</ToolLayout>
