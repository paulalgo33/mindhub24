---
import ToolLayout from '@/layouts/ToolLayout.astro';
---

<ToolLayout title="Неотправленное письмо">
  <div class="max-w-[640px] mx-auto">
    <!-- Header -->
    <div class="mb-10">
      <p class="s-label">Катарсис · Письмо</p>
      <h1 class="font-heading text-[clamp(2rem,5vw,3rem)] font-normal leading-[1.15] text-[var(--color-deep)] tracking-[-0.03em] mb-3">
        Неотправленное письмо
      </h1>
      <p class="text-[var(--color-text-mid)] font-light leading-relaxed">
        Напишите то, что никогда не скажете. Родителю, бывшему, себе. Получите ответ, который заслуживаете услышать.
      </p>
    </div>

    <!-- Step 1: Who to -->
    <div id="step1">
      <p class="text-sm font-medium text-[var(--color-text)] mb-3">Кому адресовано письмо?</p>
      <div class="grid grid-cols-2 gap-3 mb-6">
        {['Маме / Папе', 'Бывшему / Бывшей', 'Себе в прошлом', 'Себе сейчас', 'Другу / Подруге', 'Кому-то другому'].map(who => (
          <button
            class="recipient-btn p-4 rounded-xl border border-[var(--color-border)] text-left text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-primary)] hover:bg-[rgba(27,77,92,0.04)] transition-all duration-300"
            data-who={who}
          >{who}</button>
        ))}
      </div>
      <div id="customWhoBox" style="display:none;" class="mb-6">
        <input
          id="customWho"
          type="text"
          placeholder="Кому?"
          class="w-full p-4 rounded-xl border border-[var(--color-border)] bg-white font-body text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-primary)] transition-colors duration-300"
        />
      </div>
    </div>

    <!-- Step 2: Write -->
    <div id="step2" style="display:none;">
      <div class="mb-3 flex items-center gap-2">
        <span class="text-sm text-[var(--color-text-mid)]">Письмо для:</span>
        <span id="recipientLabel" class="text-sm font-semibold text-[var(--color-primary)]"></span>
        <button id="changeRecipient" class="text-xs text-[var(--color-text-light)] hover:text-[var(--color-primary)] ml-auto">изменить</button>
      </div>

      <!-- Paper texture card -->
      <div class="relative rounded-2xl overflow-hidden mb-4" style="box-shadow:0 8px 40px rgba(0,0,0,0.08),inset 0 1px 0 rgba(255,255,255,0.7);">
        <div class="absolute inset-0 pointer-events-none" style="background:repeating-linear-gradient(transparent,transparent 31px,rgba(27,77,92,0.06) 31px,rgba(27,77,92,0.06) 32px);top:48px;"></div>
        <textarea
          id="letterInput"
          placeholder="Дорогой..."
          class="relative w-full min-h-[280px] p-6 bg-[#FDFAF5] font-heading text-base text-[var(--color-text)] leading-[2rem] resize-none outline-none font-light"
          style="line-height:2rem;"
        ></textarea>
      </div>

      <div class="flex items-center justify-between">
        <p class="text-xs text-[var(--color-text-light)]">Письмо нигде не сохраняется</p>
        <button id="sendBtn" class="btn-primary">
          <span>Отправить</span>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </div>
    </div>

    <!-- Loading -->
    <div id="loadingSection" style="display:none;" class="text-center py-14">
      <div class="breath-ring mx-auto mb-5"></div>
      <p class="text-[var(--color-text-mid)] font-light text-sm">Читаю ваше письмо...</p>
    </div>

    <!-- Crisis -->
    <div id="crisisSection" style="display:none;" class="p-8 rounded-2xl border-2 border-[var(--color-accent)] bg-[rgba(201,168,76,0.06)]">
      <p class="font-heading text-lg text-[var(--color-deep)] mb-4">Если вам сейчас очень тяжело — пожалуйста, позвоните. Вы не одни.</p>
      <div class="flex flex-col gap-2 text-sm font-medium text-[var(--color-text-mid)]">
        <span>🇮🇱 Израиль: Eran — <strong>1201</strong></span>
        <span>🇷🇺 Россия: <strong>8-800-2000-122</strong></span>
        <span>🆘 Экстренная помощь: <strong>112</strong></span>
      </div>
      <button id="crisisBack" class="btn-ghost mt-6 text-sm">← Вернуться</button>
    </div>

    <!-- Response -->
    <div id="responseSection" style="display:none;" class="mt-2">
      <div class="p-8 rounded-2xl border border-[var(--color-border)] bg-white" style="box-shadow:0 20px 60px rgba(0,0,0,0.05),inset 0 1px 0 rgba(255,255,255,0.8);">
        <p class="text-[0.65rem] tracking-[0.1em] uppercase font-semibold text-[var(--color-accent)] mb-4">Ответ, который вы заслуживаете услышать</p>
        <p id="responseText" class="font-heading text-lg italic leading-[1.9] text-[var(--color-deep)]"></p>
      </div>

      <!-- Reflection prompt -->
      <div class="mt-4 p-5 rounded-xl bg-[rgba(27,77,92,0.03)] border border-[rgba(27,77,92,0.07)]">
        <p class="text-sm text-[var(--color-text-mid)] font-light leading-relaxed">
          <em>Что вы чувствуете, читая этот ответ? Иногда услышать нужные слова — уже начало.</em>
        </p>
      </div>

      <!-- CTA -->
      <div class="mt-6 p-6 rounded-2xl" style="background:linear-gradient(135deg,rgba(27,77,92,0.06),rgba(201,168,76,0.04));border:1px solid rgba(27,77,92,0.12);">
        <div class="flex items-start gap-4">
          <img src="/images/alexandra-confident.png" alt="Александра" class="w-12 h-12 rounded-full object-cover flex-shrink-0" style="box-shadow:0 2px 8px rgba(0,0,0,0.12);" />
          <div>
            <p class="font-heading text-base text-[var(--color-deep)] mb-1">Инструменты помогают. Но иногда нужен человек.</p>
            <p class="text-sm text-[var(--color-text-mid)] font-light mb-4">Александра здесь — когда будете готовы.</p>
            <a href="/lp/israel#pricing" class="btn-primary" style="display:inline-flex;"><span>Записаться бесплатно</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="margin-left:6px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
          </div>
        </div>
      </div>

      <button id="resetBtn" class="btn-ghost mt-8 text-sm">← Написать ещё одно письмо</button>
    </div>
  </div>
</ToolLayout>

<style>
  .breath-ring {
    width: 60px; height: 60px; border-radius: 50%;
    border: 2px solid var(--color-primary);
    animation: breathRing 2.4s ease-in-out infinite;
  }
  @keyframes breathRing {
    0%, 100% { transform: scale(0.85); opacity: 0.4; }
    50%       { transform: scale(1.15); opacity: 1; }
  }
  .recipient-btn.selected {
    border-color: var(--color-primary) !important;
    background: rgba(27,77,92,0.06) !important;
  }
</style>

<script>
  const CRISIS_WORDS = ['суицид', 'убить себя', 'не хочу жить', 'покончить', 'покончу', 'убью себя', 'хочу умереть', 'умереть хочу', 'больше не хочу жить'];

  const step1 = document.getElementById('step1')!;
  const step2 = document.getElementById('step2')!;
  const loadingSection = document.getElementById('loadingSection')!;
  const responseSection = document.getElementById('responseSection')!;
  const crisisSection = document.getElementById('crisisSection')!;
  const recipientLabel = document.getElementById('recipientLabel')!;
  const letterInput = document.getElementById('letterInput') as HTMLTextAreaElement;
  const responseText = document.getElementById('responseText')!;
  const customWhoBox = document.getElementById('customWhoBox')!;
  const customWho = document.getElementById('customWho') as HTMLInputElement;

  let selectedWho = '';

  function show(el: HTMLElement) { el.style.display = ''; }
  function hide(el: HTMLElement) { el.style.display = 'none'; }
  function hasCrisis(text: string): boolean {
    const lower = text.toLowerCase();
    return CRISIS_WORDS.some(w => lower.includes(w));
  }
  async function typeText(el: HTMLElement, text: string, delay = 22) {
    el.textContent = '';
    for (const ch of text) {
      el.textContent += ch;
      await new Promise(r => setTimeout(r, delay));
    }
  }

  document.querySelectorAll('.recipient-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.recipient-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      const who = (btn as HTMLElement).dataset.who || '';

      if (who === 'Кому-то другому') {
        show(customWhoBox);
        selectedWho = '';
      } else {
        hide(customWhoBox);
        selectedWho = who;
        proceedToStep2();
      }
    });
  });

  customWho.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && customWho.value.trim()) {
      selectedWho = customWho.value.trim();
      proceedToStep2();
    }
  });

  function proceedToStep2() {
    if (!selectedWho) return;
    recipientLabel.textContent = selectedWho;
    hide(step1);
    show(step2);
    letterInput.focus();
  }

  document.getElementById('changeRecipient')!.addEventListener('click', () => {
    hide(step2);
    show(step1);
    selectedWho = '';
    document.querySelectorAll('.recipient-btn').forEach(b => b.classList.remove('selected'));
    hide(customWhoBox);
  });

  document.getElementById('sendBtn')!.addEventListener('click', async () => {
    const text = letterInput.value.trim();
    if (!text || text.length < 10) return;

    if (hasCrisis(text)) {
      hide(step2);
      show(crisisSection);
      return;
    }

    hide(step2);
    show(loadingSection);

    const systemPrompt = `Ты — голос принятия и понимания. Человек написал неотправленное письмо адресату: "${selectedWho}". Твоя задача — написать ответ от имени этого адресата. Ответ должен: дать то, чего человек, возможно, всегда хотел услышать; признать его чувства; содержать принятие, прощение или понимание — в зависимости от содержания письма. НЕ обесценивай боль. НЕ давай советов. Пиши от первого лица, как будто ты — тот, кому написано письмо. 3-5 предложений. Тёплый, личный тон. Русский язык.`;

    try {
      const res = await fetch('/api/claude', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 600,
          system: systemPrompt,
          messages: [{ role: 'user', content: text }],
        }),
      });

      const data = await res.json();
      const reply = data?.content?.[0]?.text || 'Что-то пошло не так. Попробуйте снова.';

      hide(loadingSection);
      show(responseSection);
      await typeText(responseText, reply, 22);
    } catch {
      hide(loadingSection);
      show(step2);
      alert('Не удалось получить ответ. Проверьте соединение и попробуйте снова.');
    }
  });

  document.getElementById('resetBtn')!.addEventListener('click', () => {
    letterInput.value = '';
    selectedWho = '';
    document.querySelectorAll('.recipient-btn').forEach(b => b.classList.remove('selected'));
    hide(customWhoBox);
    hide(responseSection);
    show(step1);
  });

  document.getElementById('crisisBack')!.addEventListener('click', () => {
    hide(crisisSection);
    show(step2);
  });
</script>
