---
import ToolLayout from '@/layouts/ToolLayout.astro';
---

<ToolLayout title="Заземление 5–4–3–2–1" dark={true}>
  <div class="max-w-[540px] mx-auto" style="color:#e6edf3;">

    <!-- Header -->
    <div class="text-center mb-10">
      <p class="s-label" style="color:rgba(201,168,76,0.8);">Техника заземления</p>
      <h1 class="font-heading text-[clamp(2rem,5vw,3rem)] font-normal leading-[1.1] tracking-[-0.03em] mb-3" style="color:#e6edf3;">5–4–3–2–1</h1>
      <p style="color:rgba(230,237,243,0.55);font-weight:300;line-height:1.7;">Этот метод возвращает вас в настоящий момент — когда тревога, паника или диссоциация.</p>
    </div>

    <!-- Start -->
    <div id="startScreen" class="text-center">
      <button id="beginBtn" class="btn-primary mx-auto" style="background:rgba(42,122,145,0.7);">
        <span>Начать</span>
      </button>
    </div>

    <!-- Slides container -->
    <div id="slideContainer" style="display:none;overflow:hidden;">
      <div id="slide" class="transition-all duration-400">

        <!-- Step display -->
        <div id="stepCard" class="p-8 rounded-2xl mb-6" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.09);">
          <!-- Progress -->
          <div class="flex gap-2 mb-6">
            {[0,1,2,3,4].map(i => (
              <div class="dot flex-1 h-1 rounded-full transition-all duration-500" data-i={i} style="background:rgba(255,255,255,0.15);"></div>
            ))}
          </div>

          <div class="text-center mb-6">
            <div id="stepNum" class="font-heading text-[5rem] leading-none mb-1" style="color:rgba(42,122,145,0.9);"></div>
            <p id="stepSense" class="font-heading text-xl mb-2" style="color:#e6edf3;"></p>
            <p id="stepPrompt" class="text-sm font-light leading-relaxed" style="color:rgba(230,237,243,0.6);"></p>
          </div>

          <!-- Input fields -->
          <div id="inputFields" class="flex flex-col gap-2"></div>
        </div>

        <!-- Navigation -->
        <div class="flex items-center gap-3">
          <button id="prevBtn" class="btn-ghost text-sm flex-shrink-0" style="color:rgba(230,237,243,0.4);display:none;">← Назад</button>
          <button id="nextBtn" class="btn-primary flex-1 justify-center" style="background:rgba(42,122,145,0.7);">Далее →</button>
        </div>
      </div>
    </div>

    <!-- Completion -->
    <div id="doneScreen" style="display:none;" class="text-center">
      <div class="text-5xl mb-6">✦</div>
      <div class="p-8 rounded-2xl mb-8" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.09);">
        <p class="font-heading text-2xl mb-3" style="color:#e6edf3;">Вы здесь.</p>
        <p class="font-heading text-xl italic" style="color:rgba(230,237,243,0.7);">Вы в безопасности. Вы справились.</p>
      </div>
      <a href="/lp/israel#pricing" class="btn-primary w-full justify-center mb-4" style="background:rgba(42,122,145,0.7);">
        <span>Хотите работать с тревогой глубже?</span>
      </a>
      <button id="restartBtn" class="btn-ghost w-full justify-center text-sm" style="color:rgba(230,237,243,0.35);">Повторить</button>
    </div>

  </div>
</ToolLayout>

<script>
  const STEPS = [
    { n: 5, sense: 'Зрение', prompt: 'Назовите 5 вещей, которые вы видите прямо сейчас.', placeholder: 'Я вижу...' },
    { n: 4, sense: 'Слух',   prompt: 'Назовите 4 звука, которые вы слышите.',             placeholder: 'Я слышу...' },
    { n: 3, sense: 'Осязание', prompt: 'Назовите 3 вещи, которые вы можете потрогать.',   placeholder: 'Я чувствую...' },
    { n: 2, sense: 'Запах',  prompt: 'Назовите 2 запаха, которые вы ощущаете.',           placeholder: 'Я чувствую запах...' },
    { n: 1, sense: 'Вкус',   prompt: 'Назовите 1 вкус, который вы сейчас ощущаете.',     placeholder: 'Я ощущаю вкус...' },
  ];

  let step = 0;
  let answers: string[][] = STEPS.map(s => Array(s.n).fill(''));

  const startScreen = document.getElementById('startScreen')!;
  const slideContainer = document.getElementById('slideContainer')!;
  const doneScreen = document.getElementById('doneScreen')!;
  const slide = document.getElementById('slide')!;
  const stepNum = document.getElementById('stepNum')!;
  const stepSense = document.getElementById('stepSense')!;
  const stepPrompt = document.getElementById('stepPrompt')!;
  const inputFields = document.getElementById('inputFields')!;
  const prevBtn = document.getElementById('prevBtn') as HTMLElement;
  const nextBtn = document.getElementById('nextBtn')!;
  const dots = document.querySelectorAll('.dot');

  function show(el: HTMLElement) { el.style.display = ''; }
  function hide(el: HTMLElement) { el.style.display = 'none'; }

  function renderStep() {
    const s = STEPS[step];
    stepNum.textContent = String(s.n);
    stepSense.textContent = s.sense;
    stepPrompt.textContent = s.prompt;

    // Dots
    dots.forEach((d, i) => {
      (d as HTMLElement).style.background = i <= step
        ? 'rgba(42,122,145,0.9)'
        : 'rgba(255,255,255,0.15)';
    });

    // Inputs
    inputFields.innerHTML = '';
    for (let i = 0; i < s.n; i++) {
      const idx = i;
      const row = document.createElement('div');
      row.className = 'flex items-center gap-2';
      row.innerHTML = `<span style="font-family:'Playfair Display',serif;font-size:1rem;font-weight:600;color:rgba(42,122,145,0.9);width:1.2rem;text-align:right;flex-shrink:0;">${i+1}</span>`;
      const input = document.createElement('input');
      input.type = 'text';
      input.placeholder = s.placeholder;
      input.value = answers[step][idx];
      input.className = 'flex-1 px-3 py-2.5 rounded-lg text-sm font-light outline-none transition-colors duration-300';
      input.style.cssText = 'background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);color:#e6edf3;';
      input.addEventListener('input', () => { answers[step][idx] = input.value; });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          const inputs = inputFields.querySelectorAll('input');
          if (idx < inputs.length - 1) (inputs[idx + 1] as HTMLInputElement).focus();
          else nextBtn.click();
        }
      });
      row.appendChild(input);
      inputFields.appendChild(row);
    }

    // Focus first empty input
    setTimeout(() => {
      const firstInput = inputFields.querySelector('input:not([value])') as HTMLInputElement
        || inputFields.querySelector('input') as HTMLInputElement;
      firstInput?.focus();
    }, 50);

    // Prev
    step > 0 ? show(prevBtn) : hide(prevBtn);

    // Next text
    nextBtn.innerHTML = step === STEPS.length - 1
      ? '<span>Завершить ✦</span>'
      : '<span>Далее →</span>';
  }

  function slideTransition(direction: 'left' | 'right', cb: () => void) {
    const x = direction === 'left' ? '-30px' : '30px';
    slide.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
    slide.style.opacity = '0'; slide.style.transform = `translateX(${x})`;
    setTimeout(() => {
      cb();
      slide.style.transform = `translateX(${direction === 'left' ? '30px' : '-30px'})`;
      requestAnimationFrame(() => {
        slide.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
        slide.style.opacity = '1'; slide.style.transform = 'translateX(0)';
      });
    }, 200);
  }

  document.getElementById('beginBtn')!.addEventListener('click', () => {
    hide(startScreen); show(slideContainer);
    renderStep();
  });

  nextBtn.addEventListener('click', () => {
    if (step < STEPS.length - 1) {
      slideTransition('left', () => { step++; renderStep(); });
    } else {
      hide(slideContainer); show(doneScreen);
    }
  });

  prevBtn.addEventListener('click', () => {
    slideTransition('right', () => { step--; renderStep(); });
  });

  document.getElementById('restartBtn')!.addEventListener('click', () => {
    step = 0;
    answers = STEPS.map(s => Array(s.n).fill(''));
    hide(doneScreen); show(slideContainer);
    slide.style.opacity = '1'; slide.style.transform = 'none';
    renderStep();
  });
</script>
