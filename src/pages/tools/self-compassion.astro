---
import ToolLayout from '@/layouts/ToolLayout.astro';
---

<ToolLayout title="Письмо себе">
  <div class="max-w-[580px] mx-auto">

    <div class="mb-10">
      <p class="s-label">Самосострадание</p>
      <h1 class="font-heading text-[clamp(2rem,5vw,2.8rem)] font-normal leading-[1.15] text-[var(--color-deep)] tracking-[-0.03em] mb-3">
        Письмо себе
      </h1>
      <p class="text-[var(--color-text-mid)] font-light leading-relaxed">
        Упражнение в сострадании к себе. Только вы и слова.
      </p>
    </div>

    <!-- Step 1: Name -->
    <div id="step1">
      <label class="block text-sm font-medium text-[var(--color-text)] mb-2">Как вас зовут?</label>
      <input
        id="nameInput"
        type="text"
        placeholder="Ваше имя..."
        class="w-full px-5 py-4 rounded-xl border border-[var(--color-border)] bg-white font-body text-base text-[var(--color-text)] outline-none focus:border-[var(--color-primary)] transition-colors duration-300 mb-4"
        style="box-shadow:inset 0 1px 0 rgba(255,255,255,0.5);"
      />
      <button id="next1" class="btn-primary">
        <span>Далее</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>

    <!-- Step 2: Write for friend -->
    <div id="step2" style="display:none;">
      <div class="p-5 rounded-xl border-l-4 border-l-[var(--color-primary)] border border-[var(--color-border)] bg-[rgba(27,77,92,0.03)] mb-6">
        <p class="text-base text-[var(--color-deep)] font-medium leading-relaxed">
          Представьте, что ваш лучший друг переживает то же, что и вы.<br />
          <span class="font-light text-[var(--color-text-mid)]">Что бы вы ему сказали?</span>
        </p>
      </div>

      <textarea
        id="letterInput"
        placeholder="Дорогой друг..."
        class="w-full min-h-[200px] p-5 rounded-2xl border border-[var(--color-border)] bg-white font-body text-base text-[var(--color-text)] leading-relaxed resize-none outline-none focus:border-[var(--color-primary)] transition-colors duration-300 font-light mb-4"
        style="box-shadow:inset 0 1px 0 rgba(255,255,255,0.5);"
      ></textarea>

      <div class="flex gap-3">
        <button id="back1" class="btn-ghost text-sm">← Назад</button>
        <button id="submit" class="btn-primary">
          <span>Прочитать письмо</span>
        </button>
      </div>
    </div>

    <!-- Result: mirror -->
    <div id="result" style="display:none;">
      <div class="mb-6 text-center">
        <p class="text-[0.75rem] tracking-[0.12em] uppercase font-semibold text-[var(--color-accent)] mb-2">А теперь прочитайте</p>
        <p class="text-sm text-[var(--color-text-mid)] font-light">Это письмо адресовано <strong id="nameDisplay" class="text-[var(--color-deep)]"></strong>.</p>
      </div>

      <!-- Letter card -->
      <div class="relative rounded-2xl overflow-hidden mb-6" style="transform:rotate(-0.4deg);box-shadow:0 12px 40px rgba(0,0,0,0.08),0 2px 6px rgba(0,0,0,0.04),inset 0 1px 0 rgba(255,255,255,0.8);">
        <!-- Paper lines -->
        <div class="absolute inset-0 pointer-events-none" style="background:repeating-linear-gradient(transparent,transparent 31px,rgba(27,77,92,0.05) 31px,rgba(27,77,92,0.05) 32px);top:56px;z-index:0;"></div>
        <div class="relative z-10 p-8 bg-[#FDFAF5]">
          <p class="text-sm text-[var(--color-text-mid)] mb-4 font-light">Дорог<span id="genderSuffix"></span> <strong id="letterName" class="text-[var(--color-deep)]"></strong>,</p>
          <p id="letterBody" class="font-heading text-base italic leading-[2rem] text-[var(--color-deep)] whitespace-pre-wrap"></p>
        </div>
      </div>

      <div class="p-5 rounded-xl bg-[rgba(201,168,76,0.06)] border border-[rgba(201,168,76,0.18)] mb-6">
        <p class="text-sm text-[var(--color-text)] font-light leading-relaxed">
          <em>Заметьте, что вы почувствовали, читая это письмо себе. Мы часто добрее к другим, чем к себе — но можем научиться иначе.</em>
        </p>
      </div>

      <div class="p-6 rounded-2xl mb-6" style="background:linear-gradient(135deg,rgba(27,77,92,0.06),rgba(201,168,76,0.04));border:1px solid rgba(27,77,92,0.12);">
        <div class="flex items-start gap-4">
          <img src="/images/alexandra-confident.png" alt="Александра" class="w-12 h-12 rounded-full object-cover flex-shrink-0" style="box-shadow:0 2px 8px rgba(0,0,0,0.12);" />
          <div>
            <p class="font-heading text-base text-[var(--color-deep)] mb-1">Инструменты помогают. Но иногда нужен человек.</p>
            <p class="text-sm text-[var(--color-text-mid)] font-light mb-4">Александра здесь — когда будете готовы.</p>
            <a href="/lp/israel#pricing" class="btn-primary" style="display:inline-flex;"><span>Записаться бесплатно</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="margin-left:6px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
          </div>
        </div>
      </div>

      <button id="restart" class="btn-ghost text-sm">← Написать ещё раз</button>
    </div>

  </div>
</ToolLayout>

<script>
  function show(el: HTMLElement) { el.style.display = ''; }
  function hide(el: HTMLElement) { el.style.display = 'none'; }

  const step1 = document.getElementById('step1')!;
  const step2 = document.getElementById('step2')!;
  const result = document.getElementById('result')!;
  const nameInput = document.getElementById('nameInput') as HTMLInputElement;
  const letterInput = document.getElementById('letterInput') as HTMLTextAreaElement;

  let userName = '';

  document.getElementById('next1')!.addEventListener('click', () => {
    userName = nameInput.value.trim();
    if (!userName) return;
    hide(step1); show(step2); letterInput.focus();
  });

  nameInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('next1')!.click();
  });

  document.getElementById('back1')!.addEventListener('click', () => {
    hide(step2); show(step1);
  });

  document.getElementById('submit')!.addEventListener('click', () => {
    const letter = letterInput.value.trim();
    if (letter.length < 10) return;

    (document.getElementById('nameDisplay')! as HTMLElement).textContent = userName;
    (document.getElementById('letterName')! as HTMLElement).textContent = userName;
    (document.getElementById('letterBody')! as HTMLElement).textContent = letter;

    // Guess gender suffix heuristically — default to neutral
    const last = userName.slice(-1).toLowerCase();
    const suffix = (last === 'а' || last === 'я') ? 'ая' : 'ой';
    (document.getElementById('genderSuffix')! as HTMLElement).textContent = suffix;

    hide(step2); show(result);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  document.getElementById('restart')!.addEventListener('click', () => {
    nameInput.value = ''; letterInput.value = '';
    hide(result); show(step1);
  });
</script>
