---
import MainLayout from '@/layouts/MainLayout.astro';
import BookingCTA from '@/components/BookingCTA.astro';
---

<MainLayout
  title="Техники самопомощи — MindHub24 | Бесплатные психологические упражнения"
  description="Бесплатные научно обоснованные техники самопомощи. Выберите то, что чувствуете — и попробуйте прямо сейчас. Анонимно. Без регистрации."
>

<style>
@keyframes floatA {
  0%, 100% { transform: translateY(0px) translateX(0px); }
  50% { transform: translateY(-14px) translateX(6px); }
}
@keyframes floatB {
  0%, 100% { transform: translateY(0px) translateX(0px); }
  50% { transform: translateY(10px) translateX(-8px); }
}
@keyframes floatC {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
}
.hero-circle-a { animation: floatA 9s ease-in-out infinite; }
.hero-circle-b { animation: floatB 7s ease-in-out infinite; }
.hero-circle-c { animation: floatC 11s ease-in-out infinite; }
.hero-circle-d { animation: floatB 8s ease-in-out infinite 2s; }
</style>

<!-- ACT 1: HERO -->
<section class="relative py-20 md:py-28 px-4 overflow-hidden" style="background: linear-gradient(135deg, #0F2E38 0%, #1B4D5C 60%, #2A6E82 100%);">
  <!-- Decorative floating circles -->
  <div class="hero-circle-a absolute top-12 left-[8%] w-48 h-48 rounded-full pointer-events-none" style="background:rgba(255,255,255,0.04);"></div>
  <div class="hero-circle-b absolute bottom-8 right-[6%] w-72 h-72 rounded-full pointer-events-none" style="background:rgba(201,168,76,0.06);"></div>
  <div class="hero-circle-c absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full pointer-events-none" style="background:rgba(255,255,255,0.02);"></div>
  <div class="hero-circle-d absolute top-8 right-[20%] w-24 h-24 rounded-full pointer-events-none" style="background:rgba(201,168,76,0.05);"></div>

  <div class="relative z-10 max-w-2xl mx-auto text-center">
    <p class="text-xs font-medium tracking-widest uppercase mb-5 text-white/60">Бесплатно · Анонимно · Без регистрации</p>

    <h1 class="font-heading text-3xl md:text-[2.8rem] leading-[1.15] mb-6 text-white tracking-[-0.02em]">
      Вам не нужно записываться,<br/>чтобы получить помощь
    </h1>

    <p class="text-lg leading-relaxed mb-4 text-white/70">
      Мы собрали техники, которые действительно работают. Каждая основана на методах доказательной психологии. Каждая бесплатна.
    </p>

    <p class="text-lg leading-relaxed mb-10 font-medium text-white">
      Просто выберите, что вы чувствуете, и попробуйте.
    </p>

    <div class="flex flex-wrap justify-center gap-3">
      <span class="flex items-center gap-1.5 px-4 py-2 rounded-full text-sm border text-white" style="background:rgba(255,255,255,0.1);border-color:rgba(255,255,255,0.2);">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        Полностью анонимно
      </span>
      <span class="flex items-center gap-1.5 px-4 py-2 rounded-full text-sm border text-white" style="background:rgba(255,255,255,0.1);border-color:rgba(255,255,255,0.2);">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Научно обоснованно
      </span>
      <span class="flex items-center gap-1.5 px-4 py-2 rounded-full text-sm border text-white" style="background:rgba(255,255,255,0.1);border-color:rgba(255,255,255,0.2);">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        2–10 минут
      </span>
      <span class="flex items-center gap-1.5 px-4 py-2 rounded-full text-sm border text-white" style="background:rgba(255,255,255,0.1);border-color:rgba(255,255,255,0.2);">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.61a19.79 19.79 0 01-3.07-8.72A2 2 0 012.18 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.14a16 16 0 006.29 6.29l1.41-1.41a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 15.27z"/></svg>
        Без регистрации
      </span>
    </div>
  </div>
</section>

<!-- FEELING NAV (sticky) -->
<div id="feelingNav" class="sticky top-16 z-30 py-3 px-4 border-b overflow-x-auto transition-shadow duration-300" style="background: white; border-color: var(--color-border);">
  <div class="flex gap-2 max-w-5xl mx-auto whitespace-nowrap">
    <a href="#calm" data-nav="calm" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 border border-[var(--color-border)] hover:text-white hover:bg-[var(--color-primary)] hover:border-[var(--color-primary)]" style="color: var(--color-deep);">Не могу успокоиться</a>
    <a href="#empty" data-nav="empty" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 border border-[var(--color-border)] hover:text-white hover:bg-[var(--color-primary)] hover:border-[var(--color-primary)]" style="color: var(--color-deep);">Нет сил</a>
    <a href="#sleep" data-nav="sleep" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 border border-[var(--color-border)] hover:text-white hover:bg-[var(--color-primary)] hover:border-[var(--color-primary)]" style="color: var(--color-deep);">Не могу уснуть</a>
    <a href="#pain" data-nav="pain" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 border border-[var(--color-border)] hover:text-white hover:bg-[var(--color-primary)] hover:border-[var(--color-primary)]" style="color: var(--color-deep);">Больно внутри</a>
    <a href="#lonely" data-nav="lonely" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 border border-[var(--color-border)] hover:text-white hover:bg-[var(--color-primary)] hover:border-[var(--color-primary)]" style="color: var(--color-deep);">Одиноко</a>
    <a href="#angry" data-nav="angry" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 border border-[var(--color-border)] hover:text-white hover:bg-[var(--color-primary)] hover:border-[var(--color-primary)]" style="color: var(--color-deep);">Всё раздражает</a>
    <a href="#lost" data-nav="lost" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 border border-[var(--color-border)] hover:text-white hover:bg-[var(--color-primary)] hover:border-[var(--color-primary)]" style="color: var(--color-deep);">Не знаю, кто я</a>
    <a href="#quiet" data-nav="quiet" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 border border-[var(--color-border)] hover:text-white hover:bg-[var(--color-primary)] hover:border-[var(--color-primary)]" style="color: var(--color-deep);">Хочу тишины</a>
  </div>
</div>

<!-- ACT 2: 8 FEELING SECTIONS -->

<!-- SECTION 1: Не могу успокоиться -->
<section id="calm" class="py-14 px-4" style="background: var(--color-cream);">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-4 mb-4">
      <div class="w-14 h-14 rounded-2xl flex items-center justify-center flex-shrink-0" style="background:#E07A5F20;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#E07A5F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      <div>
        <h2 class="font-heading text-2xl md:text-3xl" style="color: var(--color-deep); border-left: 4px solid #E07A5F; padding-left: 12px;">«Не могу успокоиться»</h2>
        <p class="text-base mt-1" style="color: var(--color-text-mid);">Сердце колотится. Мысли по кругу. Тело не отпускает.</p>
      </div>
    </div>
    <p class="text-xs px-3 py-1.5 rounded-lg inline-block mb-8" style="background: var(--color-warm); color: var(--color-text-light);">
      Методы: когнитивно-поведенческий подход, диафрагмальное дыхание, техники заземления
    </p>
    <div class="tools-grid grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <a href="/tools/breathe" class="group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block" style="border-top: 3px solid #E07A5F;">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Подышать</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">3 минуты. Вдох, пауза, выдох. Тело успокоится само.</p>
        <div class="flex items-center justify-between">
          <span class="text-xs px-2 py-0.5 rounded-full font-medium text-white" style="background:#E07A5F;">3 мин</span>
          <span class="inline-flex items-center gap-1 text-xs transition-all duration-200 group-hover:gap-2" style="color:#E07A5F;">Попробовать <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/tools/ground" class="group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block" style="border-top: 3px solid #E07A5F;">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Вернуться в тело</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">5 вещей вижу, 4 слышу, 3 чувствую. Техника заземления.</p>
        <div class="flex items-center justify-between">
          <span class="text-xs px-2 py-0.5 rounded-full font-medium text-white" style="background:#E07A5F;">5 мин</span>
          <span class="inline-flex items-center gap-1 text-xs transition-all duration-200 group-hover:gap-2" style="color:#E07A5F;">Попробовать <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/tools/reframe" class="group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block" style="border-top: 3px solid #E07A5F;">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Посмотреть иначе</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Запишите тревожную мысль. Получите мягкий взгляд со стороны.</p>
        <div class="flex items-center justify-between">
          <span class="text-xs px-2 py-0.5 rounded-full font-medium text-white" style="background:#E07A5F;">5 мин</span>
          <span class="inline-flex items-center gap-1 text-xs transition-all duration-200 group-hover:gap-2" style="color:#E07A5F;">Попробовать <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/tools/studio" class="group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block" style="border-top: 3px solid #E07A5F;">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Включить дождь</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Звуки природы + частота 396 Гц. Просто слушайте.</p>
        <div class="flex items-center justify-between">
          <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(27,77,92,0.08);color:var(--color-primary);">∞ · Студия</span>
          <span class="inline-flex items-center gap-1 text-xs transition-all duration-200 group-hover:gap-2" style="color:#E07A5F;">Попробовать <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
    </div>
    <p class="text-sm italic"><a href="/services/anxiety" class="hover:underline" style="color:#E07A5F;">Если тревога не отпускает неделями — поговорите с Александрой →</a></p>
  </div>
</section>

<!-- IMAGE BREAK 1 -->
<div class="my-0 max-w-5xl mx-auto px-4 py-6 section-image">
  <img src="/images/stock/anxious.jpg" alt="" class="w-full h-48 md:h-64 object-cover rounded-2xl opacity-80" loading="lazy" />
</div>

<!-- SECTION 2: Нет сил -->
<section id="empty" class="py-14 px-4" style="background: white;">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-4 mb-4">
      <div class="w-14 h-14 rounded-2xl flex items-center justify-center flex-shrink-0" style="background:#8B9DC320;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#8B9DC3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="11" rx="2" ry="2"/><path d="M22 11V9a2 2 0 00-2-2H4a2 2 0 00-2 2v2"/><line x1="6" y1="12" x2="10" y2="12" stroke-width="2.5"/></svg>
      </div>
      <div>
        <h2 class="font-heading text-2xl md:text-3xl" style="color: var(--color-deep); border-left: 4px solid #8B9DC3; padding-left: 12px;">«Нет сил»</h2>
        <p class="text-base mt-1" style="color: var(--color-text-mid);">Утром не хочется вставать. Ничего не радует. Внутри — пусто.</p>
      </div>
    </div>
    <p class="text-xs px-3 py-1.5 rounded-lg inline-block mb-8" style="background: var(--color-warm); color: var(--color-text-light);">
      Методы: поведенческая активация, практика благодарности, журналирование
    </p>
    <div class="tools-grid grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <a href="/tools/journal" class="group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block" style="border-top: 3px solid #8B9DC3;">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Написать, что чувствую</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Не нужно формулировать красиво. Просто выплесните.</p>
        <div class="flex items-center justify-between">
          <span class="text-xs px-2 py-0.5 rounded-full font-medium text-white" style="background:#8B9DC3;">5 мин</span>
          <span class="inline-flex items-center gap-1 text-xs transition-all duration-200 group-hover:gap-2" style="color:#8B9DC3;">Попробовать <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/tools/gratitude" class="group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block" style="border-top: 3px solid #8B9DC3;">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Заметить хорошее</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Одна маленькая хорошая вещь в день. Это работает.</p>
        <div class="flex items-center justify-between">
          <span class="text-xs px-2 py-0.5 rounded-full font-medium text-white" style="background:#8B9DC3;">2 мин</span>
          <span class="inline-flex items-center gap-1 text-xs transition-all duration-200 group-hover:gap-2" style="color:#8B9DC3;">Попробовать <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/tools/mood" class="group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block" style="border-top: 3px solid #8B9DC3;">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Проследить за настроением</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">7 дней наблюдений. На седьмой — персональный анализ.</p>
        <div class="flex items-center justify-between">
          <span class="text-xs px-2 py-0.5 rounded-full font-medium text-white" style="background:#8B9DC3;">1 мин/день</span>
          <span class="inline-flex items-center gap-1 text-xs transition-all duration-200 group-hover:gap-2" style="color:#8B9DC3;">Попробовать <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/tools/studio" class="group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block" style="border-top: 3px solid #8B9DC3;">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Медитация благодарности</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">3 минуты тишины и внимания к хорошему.</p>
        <div class="flex items-center justify-between">
          <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(27,77,92,0.08);color:var(--color-primary);">3 мин · Студия</span>
          <span class="inline-flex items-center gap-1 text-xs transition-all duration-200 group-hover:gap-2" style="color:#8B9DC3;">Попробовать <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
    </div>
    <p class="text-sm italic"><a href="/services/depression" class="hover:underline" style="color:#8B9DC3;">Если пустота длится недели — вы заслуживаете поддержки →</a></p>
  </div>
</section>

<!-- SECTION 3: Не могу уснуть -->
<section id="sleep" class="py-14 px-4" style="background: var(--color-cream);">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-4 mb-4">
      <div class="w-14 h-14 rounded-2xl flex items-center justify-center flex-shrink-0" style="background:#6C5B7B20;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#6C5B7B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
      </div>
      <div>
        <h2 class="font-heading text-2xl md:text-3xl" style="color: var(--color-deep); border-left: 4px solid #6C5B7B; padding-left: 12px;">«Не могу уснуть»</h2>
        <p class="text-base mt-1" style="color: var(--color-text-mid);">3 часа ночи. Мысли не выключаются. Тело устало, голова — нет.</p>
      </div>
    </div>
    <p class="text-xs px-3 py-1.5 rounded-lg inline-block mb-8" style="background: var(--color-warm); color: var(--color-text-light);">
      Методы: когнитивная терапия бессонницы, прогрессивная релаксация, дыхательные техники
    </p>
    <div class="tools-grid grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <a href="/tools/breathe" class="group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block" style="border-top: 3px solid #6C5B7B;">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Дыхание для сна</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Техника 4-7-8. Естественный способ замедлить нервную систему.</p>
        <div class="flex items-center justify-between">
          <span class="text-xs px-2 py-0.5 rounded-full font-medium text-white" style="background:#6C5B7B;">3 мин</span>
          <span class="inline-flex items-center gap-1 text-xs transition-all duration-200 group-hover:gap-2" style="color:#6C5B7B;">Попробовать <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/tools/body-scan" class="group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block" style="border-top: 3px solid #6C5B7B;">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Расслабить тело</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Пройдите вниманием от макушки до стоп. Тело отпустит.</p>
        <div class="flex items-center justify-between">
