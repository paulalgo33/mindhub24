---
import ToolLayout from '@/layouts/ToolLayout.astro';
---

<ToolLayout title="Инструменты заботы о себе">

  <!-- Hero -->
  <div class="tools-hero py-16 px-[clamp(1.5rem,4vw,3rem)] text-center" style="background:linear-gradient(160deg,var(--color-cream) 0%,var(--color-warm) 100%);">
    <p class="s-label mb-3">Бесплатно · Анонимно · Без регистрации</p>
    <h1 class="font-heading text-[clamp(2.4rem,6vw,3.8rem)] font-normal leading-[1.1] text-[var(--color-deep)] tracking-[-0.04em] mb-4">
      Инструменты заботы о себе
    </h1>
    <p class="text-[1.1rem] text-[var(--color-text-mid)] font-light leading-relaxed max-w-[480px] mx-auto">
      Выберите то, что вам нужно прямо сейчас.
    </p>
  </div>

  <!-- SECTION 1: Мне плохо -->
  <section class="tools-section py-14 px-[clamp(1.5rem,4vw,3rem)]" style="background:var(--color-cream);" data-section="1">
    <div class="max-w-[860px] mx-auto">
      <div class="section-header mb-8 pl-4" style="border-left:3px solid #e07a5f;">
        <h2 class="font-heading text-2xl text-[var(--color-deep)] mb-1">Мне плохо прямо сейчас</h2>
        <p class="text-sm text-[var(--color-text-mid)] font-light">Если тревога, паника или бессонница — начните здесь.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/tools/breathe" class="tool-card group block p-6 bg-white rounded-xl border border-[var(--color-border)] no-underline transition-all duration-400 hover:-translate-y-1 hover:border-[#e07a5f] hover:shadow-[0_12px_40px_rgba(224,122,95,0.12)]" data-animate>
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:rgba(224,122,95,0.1);color:#e07a5f;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 12c0-3-3-5-3-8a3 3 0 0 1 6 0c0 3-3 5-3 8"/><path d="M12 12c3 0 5-3 8-3a3 3 0 0 1 0 6c-3 0-5-3-8-3"/><path d="M12 12c0 3 3 5 3 8a3 3 0 0 1-6 0c0-3 3-5 3-8"/><path d="M12 12c-3 0-5 3-8 3a3 3 0 0 1 0-6c3 0 5 3 8 3"/></svg>
            </div>
            <span class="time-pill text-[0.65rem] px-2 py-0.5 rounded-full font-medium" style="background:rgba(224,122,95,0.1);color:#e07a5f;">3 мин</span>
          </div>
          <p class="font-heading text-base font-semibold text-[var(--color-deep)] mb-1">Дыши со мной</p>
          <p class="text-[0.82rem] text-[var(--color-text-mid)] font-light leading-relaxed">Персональное дыхание под ваше состояние</p>
          <div class="mt-3 flex items-center gap-1.5">
            <span class="time-pill text-[0.65rem] px-2 py-0.5 rounded-full font-medium" style="background:rgba(27,77,92,0.08);color:var(--color-primary);">3 мин</span>
          </div>
        </a>

        <a href="/tools/ground" class="tool-card group block p-6 bg-white rounded-xl border border-[var(--color-border)] no-underline transition-all duration-400 hover:-translate-y-1 hover:border-[#e07a5f] hover:shadow-[0_12px_40px_rgba(224,122,95,0.12)]" data-animate>
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:rgba(224,122,95,0.1);color:#e07a5f;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v10"/><path d="M8 6l4 6 4-6"/><path d="M5 20h14"/><path d="M8 14v6"/><path d="M16 14v6"/><path d="M5 14h14"/></svg>
            </div>
            <span class="time-pill text-[0.65rem] px-2 py-0.5 rounded-full font-medium" style="background:rgba(224,122,95,0.1);color:#e07a5f;">5 мин</span>
          </div>
          <p class="font-heading text-base font-semibold text-[var(--color-deep)] mb-1">Заземление 5–4–3–2–1</p>
          <p class="text-[0.82rem] text-[var(--color-text-mid)] font-light leading-relaxed">Вернуться в тело, в настоящий момент</p>
        </a>

        <a href="/tools/body-scan" class="tool-card group block p-6 bg-white rounded-xl border border-[var(--color-border)] no-underline transition-all duration-400 hover:-translate-y-1 hover:border-[#e07a5f] hover:shadow-[0_12px_40px_rgba(224,122,95,0.12)]" data-animate>
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:rgba(224,122,95,0.1);color:#e07a5f;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="5" r="2"/><path d="M12 7v6"/><path d="M9 10l3 2 3-2"/><path d="M9 21l3-3 3 3"/></svg>
            </div>
            <span class="time-pill text-[0.65rem] px-2 py-0.5 rounded-full font-medium" style="background:rgba(224,122,95,0.1);color:#e07a5f;">5 мин</span>
          </div>
          <p class="font-heading text-base font-semibold text-[var(--color-deep)] mb-1">Сканирование тела</p>
          <p class="text-[0.82rem] text-[var(--color-text-mid)] font-light leading-relaxed">Отметьте, что чувствуете в каждой зоне</p>
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Я хочу разобраться -->
  <section class="tools-section py-14 px-[clamp(1.5rem,4vw,3rem)]" style="background:var(--color-warm);" data-section="2">
    <div class="max-w-[860px] mx-auto">
      <div class="section-header mb-8 pl-4" style="border-left:3px solid #2a7a91;">
        <h2 class="font-heading text-2xl text-[var(--color-deep)] mb-1">Я хочу разобраться</h2>
        <p class="text-sm text-[var(--color-text-mid)] font-light">Понять свои чувства, мысли, паттерны.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="/tools/journal" class="tool-card group block p-6 bg-white rounded-xl border border-[var(--color-border)] no-underline transition-all duration-400 hover:-translate-y-1 hover:border-[#2a7a91] hover:shadow-[0_12px_40px_rgba(42,122,145,0.12)]" data-animate>
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:rgba(42,122,145,0.1);color:#2a7a91;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/><path d="M15 5l3 3"/></svg>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="time-pill text-[0.65rem] px-2 py-0.5 rounded-full font-medium" style="background:rgba(42,122,145,0.08);color:#2a7a91;">2 мин</span>
            </div>
          </div>
          <p class="font-heading text-base font-semibold text-[var(--color-deep)] mb-1">Дневник чувств</p>
          <p class="text-[0.82rem] text-[var(--color-text-mid)] font-light leading-relaxed">Напишите, что чувствуете. Получите тёплый отклик.</p>
        </a>

        <a href="/tools/reframe" class="tool-card group block p-6 bg-white rounded-xl border border-[var(--color-border)] no-underline transition-all duration-400 hover:-translate-y-1 hover:border-[#2a7a91] hover:shadow-[0_12px_40px_rgba(42,122,145,0.12)]" data-animate>
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:rgba(42,122,145,0.1);color:#2a7a91;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M1 4v6h6"/><path d="M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="time-pill text-[0.65rem] px-2 py-0.5 rounded-full font-medium" style="background:rgba(42,122,145,0.08);color:#2a7a91;">2 мин</span>
            </div>
          </div>
          <p class="font-heading text-base font-semibold text-[var(--color-deep)] mb-1">Другой взгляд</p>
          <p class="text-[0.82rem] text-[var(--color-text-mid)] font-light leading-relaxed">Мягкое переосмысление тревожных мыслей</p>
        </a>

        <a href="/tools/mood" class="tool-card group block p-6 bg-white rounded-xl border border-[var(--color-border)] no-underline transition-all duration-400 hover:-translate-y-1 hover:border-[#2a7a91] hover:shadow-[0_12px_40px_rgba(42,122,145,0.12)]" data-animate>
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:rgba(42,122,145,0.1);color:#2a7a91;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="time-pill text-[0.65rem] px-2 py-0.5 rounded-full font-medium" style="background:rgba(42,122,145,0.08);color:#2a7a91;">7 дней</span>
            </div>
          </div>
          <p class="font-heading text-base font-semibold text-[var(--color-deep)] mb-1">Карта настроения</p>
          <p class="text-[0.82rem] text-[var(--color-text-mid)] font-light leading-relaxed">7-дневный трекер настроения</p>
        </a>

        <a href="/tools/self-compassion" class="tool-card group block p-6 bg-white rounded-xl border border-[var(--color-border)] no-underline transition-all duration-400 hover:-translate-y-1 hover:border-[#2a7a91] hover:shadow-[0_12px_40px_rgba(42,122,145,0.12)]" data-animate>
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:rgba(42,122,145,0.1);color:#2a7a91;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
            </div>
            <span class="time-pill text-[0.65rem] px-2 py-0.5 rounded-full font-medium" style="background:rgba(42,122,145,0.08);color:#2a7a91;">5 мин</span>
          </div>
          <p class="font-heading text-base font-semibold text-[var(--color-deep)] mb-1">Письмо себе</p>
          <p class="text-[0.82rem] text-[var(--color-text-mid)] font-light leading-relaxed">Напишите себе так, как другу.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Мне нужно выговориться -->
  <section class="tools-section py-14 px-[clamp(1.5rem,4vw,3rem)]" style="background:var(--color-cream);" data-section="3">
    <div class="max-w-[860px] mx-auto">
      <div class="section-header mb-8 pl-4" style="border-left:3px solid #7c6fa0;">
        <h2 class="font-heading text-2xl text-[var(--color-deep)] mb-1">Мне нужно выговориться</h2>
        <p class="text-sm text-[var(--color-text-mid)] font-light">Сказать то, что вы никогда не говорили.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/tools/unsent" class="tool-card group block p-6 bg-white rounded-xl border border-[var(--color-border)] no-underline transition-all duration-400 hover:-translate-y-1 hover:border-[#7c6fa0] hover:shadow-[0_12px_40px_rgba(124,111,160,0.12)]" data-animate>
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:rgba(124,111,160,0.1);color:#7c6fa0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="time-pill text-[0.65rem] px-2 py-0.5 rounded-full font-medium" style="background:rgba(124,111,160,0.08);color:#7c6fa0;">5 мин</span>
            </div>
          </div>
          <p class="font-heading text-base font-semibold text-[var(--color-deep)] mb-1">Неотправленное письмо</p>
          <p class="text-[0.82rem] text-[var(--color-text-mid)] font-light leading-relaxed">Напишите то, что не скажете. Получите ответ.</p>
        </a>

        <a href="/tools/worry-tree" class="tool-card group block p-6 bg-white rounded-xl border border-[var(--color-border)] no-underline transition-all duration-400 hover:-translate-y-1 hover:border-[#7c6fa0] hover:shadow-[0_12px_40px_rgba(124,111,160,0.12)]" data-animate>
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:rgba(124,111,160,0.1);color:#7c6fa0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M12 12C12 7 6 6 4 9c2 0 5 1 8 3z"/><path d="M12 12C12 7 18 6 20 9c-2 0-5 1-8 3z"/><path d="M12 18C12 14 7 12 5 14c2 0 5 2 7 4z"/></svg>
            </div>
            <span class="time-pill text-[0.65rem] px-2 py-0.5 rounded-full font-medium" style="background:rgba(124,111,160,0.08);color:#7c6fa0;">3 мин</span>
          </div>
          <p class="font-heading text-base font-semibold text-[var(--color-deep)] mb-1">Дерево тревоги</p>
          <p class="text-[0.82rem] text-[var(--color-text-mid)] font-light leading-relaxed">CBT-решение: что с этим делать?</p>
        </a>

        <a href="/first-words" class="tool-card group block p-6 bg-white rounded-xl border border-[var(--color-border)] no-underline transition-all duration-400 hover:-translate-y-1 hover:border-[#7c6fa0] hover:shadow-[0_12px_40px_rgba(124,111,160,0.12)]" data-animate>
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:rgba(124,111,160,0.1);color:#7c6fa0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
            </div>
            <span class="time-pill text-[0.65rem] px-2 py-0.5 rounded-full font-medium" style="background:rgba(124,111,160,0.08);color:#7c6fa0;">10 мин</span>
          </div>
          <p class="font-heading text-base font-semibold text-[var(--color-deep)] mb-1">Первая встреча</p>
          <p class="text-[0.82rem] text-[var(--color-text-mid)] font-light leading-relaxed">Симуляция: как это бывает с психологом</p>
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 4: Мне нужен человек — THE POINT OF THIS PAGE -->
  <section class="py-20 px-[clamp(1.5rem,4vw,3rem)]" style="background:linear-gradient(160deg,#0a1f28 0%,#0F2E38 100%);">
    <div class="max-w-[680px] mx-auto text-center">
      <img
        src="/images/alexandra-hero.jpeg"
        alt="Александра"
        class="w-20 h-20 rounded-full object-cover mx-auto mb-6"
        style="box-shadow:0 0 0 4px rgba(201,168,76,0.3),0 8px 32px rgba(0,0,0,0.3);"
      />
      <p class="text-xs tracking-[0.15em] uppercase font-semibold mb-4" style="color:rgba(201,168,76,0.7);">Александра · Психолог-консультант</p>
      <h2 class="font-heading text-[clamp(1.8rem,4vw,2.8rem)] font-normal leading-[1.2] tracking-[-0.02em] mb-4" style="color:#e6edf3;">
        Инструменты помогают.<br />Но иногда нужен человек.
      </h2>
      <p class="text-[1.05rem] font-light mb-8 max-w-[440px] mx-auto leading-relaxed" style="color:rgba(230,237,243,0.65);">
        Александра здесь — когда будете готовы. Первая встреча бесплатно, без обязательств.
      </p>
      <a href="/lp/israel#pricing" class="btn-primary text-base py-4 px-8 mx-auto" style="background:rgba(42,122,145,0.8);display:inline-flex;">
        <span>Записаться на бесплатную встречу</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <p class="text-xs mt-4" style="color:rgba(230,237,243,0.3);">Онлайн · На русском языке · Без осуждения</p>
    </div>
  </section>

  <!-- Footer note -->
  <div class="py-8 px-[clamp(1.5rem,4vw,3rem)] border-t border-[var(--color-border)] text-center" style="background:var(--color-cream);">
    <p class="text-xs text-[var(--color-text-light)] max-w-[520px] mx-auto leading-relaxed">
      Все инструменты бесплатны. Ваши данные не сохраняются на сервере. Это не терапия — но это может помочь прямо сейчас.<br />
      <strong>Кризис:</strong> Израиль Eran 1201 · Россия 8-800-2000-122 · Экстренно 112
    </p>
  </div>

</ToolLayout>

<script>
  // GSAP stagger entrance per section
  if (typeof window !== 'undefined') {
    const load = () => {
      if (!(window as any).gsap) return;
      const gsap = (window as any).gsap;
      const ScrollTrigger = (window as any).ScrollTrigger;
      if (!ScrollTrigger) return;

      document.querySelectorAll('.tools-section').forEach(section => {
        const cards = section.querySelectorAll('[data-animate]');
        gsap.from(cards, {
          scrollTrigger: { trigger: section, start: 'top 80%' },
          opacity: 0,
          y: 28,
          duration: 0.6,
          ease: 'power3.out',
          stagger: 0.1,
        });
        const header = section.querySelector('.section-header');
        if (header) {
          gsap.from(header, {
            scrollTrigger: { trigger: section, start: 'top 85%' },
            opacity: 0,
            x: -20,
            duration: 0.5,
            ease: 'power3.out',
          });
        }
      });
    };
    document.addEventListener('DOMContentLoaded', () => setTimeout(load, 200));
  }
</script>
