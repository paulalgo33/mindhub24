---
import MainLayout from '@/layouts/MainLayout.astro';
import BookingCTA from '@/components/BookingCTA.astro';
---

<MainLayout
  title="Техники самопомощи — MindHub24 | Бесплатные психологические упражнения"
  description="Бесплатные научно обоснованные техники самопомощи. Выберите то, что чувствуете — и попробуйте прямо сейчас. Анонимно. Без регистрации."
>

<!-- ACT 1: THE OPENING -->
<section class="py-16 md:py-24 px-4" style="background: var(--color-cream);">
  <div class="max-w-2xl mx-auto text-center">
    <p class="text-sm font-medium tracking-widest uppercase mb-4" style="color: var(--color-primary);">Бесплатно · Анонимно · Без регистрации</p>

    <h1 class="font-heading text-3xl md:text-4xl mb-6" style="color: var(--color-deep);">
      Вам не нужно записываться,<br/>чтобы получить помощь
    </h1>

    <p class="text-lg leading-relaxed mb-4" style="color: var(--color-text-mid);">
      Мы собрали техники, которые действительно работают. Каждая основана на методах доказательной психологии. Каждая бесплатна. Мы не просим email, не сохраняем данные, не отслеживаем вас.
    </p>

    <p class="text-lg leading-relaxed mb-8 font-medium" style="color: var(--color-deep);">
      Просто выберите, что вы чувствуете, и попробуйте.
    </p>

    <div class="flex flex-wrap justify-center gap-3">
      <span class="flex items-center gap-1.5 px-4 py-2 rounded-full text-sm bg-white shadow-sm" style="color: var(--color-deep);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        Полностью анонимно
      </span>
      <span class="flex items-center gap-1.5 px-4 py-2 rounded-full text-sm bg-white shadow-sm" style="color: var(--color-deep);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Научно обоснованно
      </span>
      <span class="flex items-center gap-1.5 px-4 py-2 rounded-full text-sm bg-white shadow-sm" style="color: var(--color-deep);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        2–10 минут
      </span>
      <span class="flex items-center gap-1.5 px-4 py-2 rounded-full text-sm bg-white shadow-sm" style="color: var(--color-deep);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><path d="M12 22c5.5 0 10-4.5 10-10S17.5 2 12 2 2 6.5 2 12s4.5 10 10 10z"/></svg>
        Без регистрации
      </span>
    </div>
  </div>
</section>

<!-- FEELING NAV (sticky) -->
<div class="sticky top-16 z-30 py-3 px-4 border-b overflow-x-auto" style="background: white; border-color: var(--color-border);">
  <div class="flex gap-2 max-w-5xl mx-auto whitespace-nowrap">
    <a href="#calm" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all hover:text-white hover:bg-[var(--color-primary)]" style="background: var(--color-warm); color: var(--color-deep);">Не могу успокоиться</a>
    <a href="#empty" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all hover:text-white hover:bg-[var(--color-primary)]" style="background: var(--color-warm); color: var(--color-deep);">Нет сил</a>
    <a href="#sleep" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all hover:text-white hover:bg-[var(--color-primary)]" style="background: var(--color-warm); color: var(--color-deep);">Не могу уснуть</a>
    <a href="#pain" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all hover:text-white hover:bg-[var(--color-primary)]" style="background: var(--color-warm); color: var(--color-deep);">Больно внутри</a>
    <a href="#lonely" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all hover:text-white hover:bg-[var(--color-primary)]" style="background: var(--color-warm); color: var(--color-deep);">Одиноко</a>
    <a href="#angry" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all hover:text-white hover:bg-[var(--color-primary)]" style="background: var(--color-warm); color: var(--color-deep);">Всё раздражает</a>
    <a href="#lost" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all hover:text-white hover:bg-[var(--color-primary)]" style="background: var(--color-warm); color: var(--color-deep);">Не знаю, кто я</a>
    <a href="#quiet" class="feeling-pill px-4 py-2 rounded-full text-sm font-medium transition-all hover:text-white hover:bg-[var(--color-primary)]" style="background: var(--color-warm); color: var(--color-deep);">Хочу тишины</a>
  </div>
</div>

<!-- ACT 2: THE 8 FEELING SECTIONS -->

<!-- SECTION 1: Не могу успокоиться -->
<section id="calm" class="py-14 px-4" style="background: var(--color-cream);">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-heading text-2xl md:text-3xl mb-2" style="color: var(--color-deep);">«Не могу успокоиться»</h2>
    <p class="text-base mb-3" style="color: var(--color-text-mid);">Сердце колотится. Мысли по кругу. Тело не отпускает.</p>
    <p class="text-xs px-3 py-1.5 rounded-lg inline-block mb-8" style="background: var(--color-warm); color: var(--color-text-light);">
      Методы: когнитивно-поведенческий подход, диафрагмальное дыхание, техники заземления
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <a href="/tools/breathe" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Подышать</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">3 минуты. Вдох, пауза, выдох. Тело успокоится само.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(201,168,76,0.1);color:var(--color-accent);">3 мин</span>
      </a>
      <a href="/tools/ground" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Вернуться в тело</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">5 вещей вижу, 4 слышу, 3 чувствую. Техника заземления.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(201,168,76,0.1);color:var(--color-accent);">5 мин</span>
      </a>
      <a href="/tools/reframe" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Посмотреть иначе</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Запишите тревожную мысль. Получите мягкий взгляд со стороны.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(201,168,76,0.1);color:var(--color-accent);">5 мин</span>
      </a>
      <a href="/tools/studio" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Включить дождь</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Звуки природы + частота 396 Гц. Просто слушайте.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(27,77,92,0.08);color:var(--color-primary);">∞ · Студия покоя</span>
      </a>
    </div>

    <p class="text-sm italic" style="color: var(--color-accent);">
      <a href="/services/anxiety" class="hover:underline" style="color:inherit;">Если тревога не отпускает неделями — поговорите с Александрой →</a>
    </p>
  </div>
</section>

<!-- SECTION 2: Нет сил -->
<section id="empty" class="py-14 px-4" style="background: white;">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-heading text-2xl md:text-3xl mb-2" style="color: var(--color-deep);">«Нет сил»</h2>
    <p class="text-base mb-3" style="color: var(--color-text-mid);">Утром не хочется вставать. Ничего не радует. Внутри — пусто.</p>
    <p class="text-xs px-3 py-1.5 rounded-lg inline-block mb-8" style="background: var(--color-warm); color: var(--color-text-light);">
      Методы: поведенческая активация, практика благодарности, журналирование
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <a href="/tools/journal" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Написать, что чувствую</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Не нужно формулировать красиво. Просто выплесните.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(201,168,76,0.1);color:var(--color-accent);">5 мин</span>
      </a>
      <a href="/tools/gratitude" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Заметить хорошее</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Одна маленькая хорошая вещь в день. Это работает.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(201,168,76,0.1);color:var(--color-accent);">2 мин</span>
      </a>
      <a href="/tools/mood" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Проследить за настроением</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">7 дней наблюдений. На седьмой — персональный анализ.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(201,168,76,0.1);color:var(--color-accent);">1 мин/день</span>
      </a>
      <a href="/tools/studio" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Медитация благодарности</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">3 минуты тишины и внимания к хорошему.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(27,77,92,0.08);color:var(--color-primary);">3 мин · Студия покоя</span>
      </a>
    </div>

    <p class="text-sm italic">
      <a href="/services/depression" class="hover:underline" style="color:var(--color-accent);">Если пустота длится недели — вы заслуживаете поддержки →</a>
    </p>
  </div>
</section>

<!-- SECTION 3: Не могу уснуть -->
<section id="sleep" class="py-14 px-4" style="background: var(--color-cream);">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-heading text-2xl md:text-3xl mb-2" style="color: var(--color-deep);">«Не могу уснуть»</h2>
    <p class="text-base mb-3" style="color: var(--color-text-mid);">3 часа ночи. Мысли не выключаются. Тело устало, голова — нет.</p>
    <p class="text-xs px-3 py-1.5 rounded-lg inline-block mb-8" style="background: var(--color-warm); color: var(--color-text-light);">
      Методы: когнитивная терапия бессонницы, прогрессивная релаксация, дыхательные техники
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <a href="/tools/breathe" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Дыхание для сна</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Техника 4-7-8. Естественный способ замедлить нервную систему.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(201,168,76,0.1);color:var(--color-accent);">3 мин</span>
      </a>
      <a href="/tools/body-scan" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Расслабить тело</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Пройдите вниманием от макушки до стоп. Тело отпустит.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(201,168,76,0.1);color:var(--color-accent);">7 мин</span>
      </a>
      <a href="/tools/studio" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Звуки для сна</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Дождь, низкие частоты, ритм глубокого сна.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(27,77,92,0.08);color:var(--color-primary);">30 мин · Студия покоя</span>
      </a>
      <a href="/tools/studio" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Медитация: сканирование тела</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Лучше снотворного. Без побочных эффектов.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(27,77,92,0.08);color:var(--color-primary);">5 мин · Студия покоя</span>
      </a>
    </div>

    <p class="text-sm italic">
      <a href="/services/anxiety" class="hover:underline" style="color:var(--color-accent);">Если бессонница длится дольше двух недель →</a>
    </p>
  </div>
</section>

<!-- SECTION 4: Больно внутри -->
<section id="pain" class="py-14 px-4" style="background: white;">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-heading text-2xl md:text-3xl mb-2" style="color: var(--color-deep);">«Больно внутри»</h2>
    <p class="text-base mb-3" style="color: var(--color-text-mid);">Что-то тяжёлое внутри. Может быть, из прошлого. Может — из настоящего.</p>
    <p class="text-xs px-3 py-1.5 rounded-lg inline-block mb-4" style="background: var(--color-warm); color: var(--color-text-light);">
      Методы: техники стабилизации и ресурсирования, используемые в работе с травмой
    </p>
    <div class="mb-6 px-4 py-3 rounded-xl text-sm" style="background: rgba(220,38,38,0.05); border: 1px solid rgba(220,38,38,0.12); color: #991b1b;">
      Эти техники помогают стабилизировать состояние. Глубокая работа с травмой требует специалиста.
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <a href="/tools/ground" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Вернуться в безопасность</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Заземление. 5 чувств. Вы здесь. Вы в безопасности.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(201,168,76,0.1);color:var(--color-accent);">5 мин</span>
      </a>
      <a href="/tools/unsent" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Написать то, что не сказал(а)</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Напишите письмо тому, кому не смогли сказать.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(201,168,76,0.1);color:var(--color-accent);">10 мин</span>
      </a>
      <a href="/tools/studio" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Безопасное место</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Визуализация пространства, где вам спокойно.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(27,77,92,0.08);color:var(--color-primary);">5 мин · Студия покоя</span>
      </a>
      <a href="/tools/breathe" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Просто дышать</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Когда больно — начните с дыхания. Остальное потом.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(201,168,76,0.1);color:var(--color-accent);">3 мин</span>
      </a>
    </div>

    <p class="text-sm italic">
      <a href="/services/trauma" class="hover:underline" style="color:var(--color-accent);">Вы пережили многое. Мы можем быть рядом. →</a>
    </p>
  </div>
</section>

<!-- SECTION 5: Одиноко -->
<section id="lonely" class="py-14 px-4" style="background: var(--color-cream);">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-heading text-2xl md:text-3xl mb-2" style="color: var(--color-deep);">«Одиноко»</h2>
    <p class="text-base mb-3" style="color: var(--color-text-mid);">Рядом люди, но поговорить не с кем. Особенно на родном языке.</p>
    <p class="text-xs px-3 py-1.5 rounded-lg inline-block mb-8" style="background: var(--color-warm); color: var(--color-text-light);">
      Методы: нарративные практики, работа с идентичностью
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <a href="/tools/journal" class="feeling-tool-card group p-5 bg-white rounded-2xl shadow-sm border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline block">
        <h3 class="font-heading text-sm font-semibold mb-1" style="color: var(--color-deep);">Написать, что на душе</h3>
        <p class="text-xs leading-snug mb-3" style="color: var(--color-text-mid);">Здесь можно на русском. Без осуждения. Без советов.</p>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background:rgba(201,168,76,0.1);color:var(--color-accent);">5 мин</span>
      </a>
