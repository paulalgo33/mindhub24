<script>
  // ── Active nav pill via IntersectionObserver ──
  const sections = document.querySelectorAll('section[id]');
  const navBar = document.getElementById('feelingNav');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        document.querySelectorAll('.feeling-pill').forEach(pill => {
          const active = (pill as HTMLElement).dataset.nav === id;
          if (active) {
            pill.classList.add('text-white', 'bg-[var(--color-primary)]', 'border-[var(--color-primary)]');
            pill.classList.remove('border-[var(--color-border)]');
            (pill as HTMLElement).style.background = 'var(--color-primary)';
            (pill as HTMLElement).style.color = 'white';
            (pill as HTMLElement).style.borderColor = 'var(--color-primary)';
          } else {
            (pill as HTMLElement).style.background = '';
            (pill as HTMLElement).style.color = 'var(--color-deep)';
            (pill as HTMLElement).style.borderColor = 'var(--color-border)';
          }
        });
      }
    });
  }, { threshold: 0.25, rootMargin: '-64px 0px -30% 0px' });

  sections.forEach(s => observer.observe(s));

  // ── Nav shadow on scroll ──
  window.addEventListener('scroll', () => {
    if (navBar) {
      navBar.style.boxShadow = window.scrollY > 80 ? '0 4px 16px rgba(0,0,0,0.07)' : 'none';
    }
  }, { passive: true });

  // ── GSAP scroll animations ──
  if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
    // Section h2 headers slide from left
    document.querySelectorAll('section[id] h2').forEach((h2: any) => {
      gsap.from(h2.closest('.flex.items-center.gap-4') || h2, {
        opacity: 0, x: -24, duration: 0.6,
        ease: 'power2.out',
        scrollTrigger: { trigger: h2, start: 'top 88%' },
      });
    });

    // Tool card grids stagger in
    document.querySelectorAll('.tools-grid').forEach((grid: any) => {
      gsap.from(Array.from(grid.children), {
        opacity: 0, y: 24, duration: 0.5, stagger: 0.1,
        ease: 'power2.out',
        scrollTrigger: { trigger: grid, start: 'top 88%' },
      });
    });

    // Image breaks scale in
    document.querySelectorAll('.section-image').forEach((el: any) => {
      gsap.from(el.querySelector('img') || el, {
        opacity: 0, scale: 0.95, duration: 0.8,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 92%' },
      });
    });

    // ACT 3 transition section
    const act3 = document.querySelector('section.py-20');
    if (act3) {
      gsap.from(act3.querySelectorAll('h2, p, .max-w-md'), {
        opacity: 0, y: 20, duration: 0.6, stagger: 0.12,
        ease: 'power2.out',
        scrollTrigger: { trigger: act3, start: 'top 85%' },
      });
    }
  }
</script>
