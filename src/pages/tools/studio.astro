// Initialize AudioContext on user gesture
document.getElementById('audioInitBtn')?.addEventListener('click', () => {
  audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
  masterGainNode = audioCtx.createGain();
  masterGainNode.gain.value = 0.7;
  masterGainNode.connect(audioCtx.destination);
  const overlay = document.getElementById('audioInitOverlay');
  if (overlay) overlay.style.display = 'none';
  initSoundCards();
  initFreqCards();
  initMeditationList();
});

// Tab switching
document.querySelectorAll('.studio-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    const tab = (btn as HTMLElement).dataset.tab!;
    document.querySelectorAll('.studio-panel').forEach(p => ((p as HTMLElement).style.display = 'none'));
    const panel = document.getElementById('tab-' + tab);
    if (panel) panel.style.display = 'block';
    document.querySelectorAll('.studio-tab').forEach(b => {
      b.classList.remove('text-white', 'border-[#C9A84C]');
      b.classList.add('text-white/50', 'border-transparent');
      (b as HTMLElement).style.borderBottomColor = '';
    });
    btn.classList.add('text-white');
    btn.classList.remove('text-white/50');
    (btn as HTMLElement).style.borderBottomColor = '#C9A84C';
  });
});

// Activate first tab visually
const firstTab = document.querySelector('.studio-tab[data-tab="sounds"]') as HTMLElement | null;
if (firstTab) {
  firstTab.style.borderBottomColor = '#C9A84C';
  firstTab.classList.add('text-white');
  firstTab.classList.remove('text-white/50');
}

// === SOUND ENGINE ===

function createNoiseBuffer(ctx: AudioContext, seconds: number = 2): AudioBuffer {
  const buf = ctx.createBuffer(1, ctx.sampleRate * seconds, ctx.sampleRate);
  const data = buf.getChannelData(0);
  for (let i = 0; i < data.length; i++) data[i] = Math.random() * 2 - 1;
  return buf;
}

function createRain(ctx: AudioContext, dest: AudioNode): any {
  const src = ctx.createBufferSource();
  src.buffer = createNoiseBuffer(ctx, 3);
  src.loop = true;
  const filter = ctx.createBiquadFilter();
  filter.type = 'bandpass';
  filter.frequency.value = 800;
  filter.Q.value = 0.7;
  const gain = ctx.createGain();
  gain.gain.value = 0;
  src.connect(filter);
  filter.connect(gain);
  gain.connect(dest);
  src.start();
  return { src, gain };
}

function createOcean(ctx: AudioContext, dest: AudioNode): any {
  const src = ctx.createBufferSource();
  src.buffer = createNoiseBuffer(ctx, 4);
  src.loop = true;
  const filter = ctx.createBiquadFilter();
  filter.type = 'lowpass';
  filter.frequency.value = 400;
  const lfo = ctx.createOscillator();
  const lfoGain = ctx.createGain();
  lfo.frequency.value = 0.08;
  lfoGain.gain.value = 350;
  lfo.connect(lfoGain);
  lfoGain.connect(filter.frequency);
  lfo.start();
  const gain = ctx.createGain();
  gain.gain.value = 0;
  src.connect(filter);
  filter.connect(gain);
  gain.connect(dest);
  src.start();
  return { src, gain };
}

function createWind(ctx: AudioContext, dest: AudioNode): any {
  const src = ctx.createBufferSource();
  src.buffer = createNoiseBuffer(ctx, 3);
  src.loop = true;
  const filter = ctx.createBiquadFilter();
  filter.type = 'bandpass';
  filter.frequency.value = 900;
  filter.Q.value = 1.5;
  const lfo = ctx.createOscillator();
  const lfoGain = ctx.createGain();
  lfo.frequency.value = 0.05;
  lfoGain.gain.value = 600;
  lfo.connect(lfoGain);
  lfoGain.connect(filter.frequency);
  lfo.start();
  const gain = ctx.createGain();
  gain.gain.value = 0;
  src.connect(filter);
  filter.connect(gain);
  gain.connect(dest);
  src.start();
  return { src, gain };
}

function createFire(ctx: AudioContext, dest: AudioNode): any {
  const src = ctx.createBufferSource();
  src.buffer = createNoiseBuffer(ctx, 2);
  src.loop = true;
  const filter = ctx.createBiquadFilter();
  filter.type = 'lowpass';
  filter.frequency.value = 300;
  const gain = ctx.createGain();
  gain.gain.value = 0;
  src.connect(filter);
  filter.connect(gain);
  gain.connect(dest);
  src.start();
  return { src, gain };
}

function createBirds(ctx: AudioContext, dest: AudioNode): any {
  const gain = ctx.createGain();
  gain.gain.value = 0;
  gain.connect(dest);
  const birdInterval = setInterval(() => {
    if (gain.gain.value > 0.01) {
      const osc = ctx.createOscillator();
      const env = ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = 2500 + Math.random() * 1500;
      osc.frequency.linearRampToValueAtTime(3500 + Math.random() * 500, ctx.currentTime + 0.08);
      env.gain.setValueAtTime(0.15, ctx.currentTime);
      env.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.08);
      osc.connect(env);
      env.connect(gain);
      osc.start();
      osc.stop(ctx.currentTime + 0.1);
    }
  }, 3000 + Math.random() * 5000);
  return { gain, birdInterval };
}

function createCafe(ctx: AudioContext, dest: AudioNode): any {
  const src = ctx.createBufferSource();
  src.buffer = createNoiseBuffer(ctx, 2);
  src.loop = true;
  const filter = ctx.createBiquadFilter();
  filter.type = 'bandpass';
  filter.frequency.value = 600;
  filter.Q.value = 0.5;
  const gain = ctx.createGain();
  gain.gain.value = 0;
  src.connect(filter);
  filter.connect(gain);
  gain.connect(dest);
  src.start();
  return { src, gain };
}

function initSoundCards(): void {
  const grid = document.getElementById('soundGrid');
  if (!grid) return;
  SOUNDS.forEach(sound => {
    const card = document.createElement('button');
    card.id = 'sound-' + sound.id;
    card.className = 'sound-card flex flex-col items-center gap-2 p-4 rounded-2xl border transition-all duration-300';
    card.style.cssText = 'background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08); cursor: pointer;';
    card.innerHTML = `
      <div class="text-3xl">${sound.icon}</div>
      <p class="text-xs text-white/60">${sound.name}</p>
      <input type="range" min="0" max="100" value="50" class="sound-vol w-full accent-[#C9A84C] mt-1" style="display:none;" />
    `;
    card.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).tagName === 'INPUT') return;
      toggleSound(sound.id, card, sound.color);
    });
    card.querySelector('input')?.addEventListener('input', (e) => {
      const vol = parseInt((e.target as HTMLInputElement).value) / 100;
      if (soundNodes[sound.id]?.gain && audioCtx) {
        soundNodes[sound.id].gain.gain.linearRampToValueAtTime(vol * 0.4, audioCtx.currentTime + 0.05);
      }
    });
    grid.appendChild(card);
  });
}

function hexToRgb(hex: string): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `${r},${g},${b}`;
}

function toggleSound(id: string, card: HTMLElement, color: string): void {
  if (!audioCtx || !masterGainNode) return;
  if (soundStates[id]) {
    const node = soundNodes[id];
    if (node?.gain && audioCtx) {
      node.gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.3);
    }
    soundStates[id] = false;
    card.style.background = 'rgba(255,255,255,0.04)';
    card.style.borderColor = 'rgba(255,255,255,0.08)';
    card.style.boxShadow = 'none';
    const volEl = card.querySelector('.sound-vol') as HTMLElement | null;
    if (volEl) volEl.style.display = 'none';
  } else {
    if (!soundNodes[id]) {
      const creators: Record<string, (ctx: AudioContext, dest: AudioNode) => any> = {
        rain: createRain,
        ocean: createOcean,
        wind: createWind,
        fire: createFire,
        birds: createBirds,
        cafe: createCafe,
      };
      soundNodes[id] = creators[id](audioCtx, masterGainNode);
    }
    const inputEl = card.querySelector('input') as HTMLInputElement | null;
    const vol = parseInt(inputEl?.value || '50') / 100;
    soundNodes[id].gain.gain.linearRampToValueAtTime(vol * 0.4, audioCtx.currentTime + 0.5);
    soundStates[id] = true;
    card.style.background = `rgba(${hexToRgb(color)},0.12)`;
    card.style.borderColor = color;
    card.style.boxShadow = `0 0 20px rgba(${hexToRgb(color)},0.15)`;
    const volEl = card.querySelector('.sound-vol') as HTMLElement | null;
    if (volEl) volEl.style.display = 'block';
  }
}

// Master volume
document.getElementById('masterVolume')?.addEventListener('input', (e) => {
  if (masterGainNode) masterGainNode.gain.value = parseInt((e.target as HTMLInputElement).value) / 100;
});

// Timer
document.querySelectorAll('.timer-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const minutes = parseInt((btn as HTMLElement).dataset.minutes || '0');
    document.querySelectorAll('.timer-btn').forEach(b => {
      b.classList.remove('text-white', 'border-white/50');
    });
    btn.classList.add('text-white', 'border-white/50');
    if (timerInterval) clearInterval(timerInterval);
    const display = document.getElementById('timerDisplay');
    if (!display) return;
    if (minutes === 0) { display.textContent = ''; return; }
    timerRemaining = minutes * 60;
    function tick(): void {
      const m = Math.floor(timerRemaining / 60);
      const s = timerRemaining % 60;
      display!.textContent = `${m}:${s.toString().padStart(2, '0')} до отключения`;
      if (timerRemaining <= 0) {
        if (timerInterval) clearInterval(timerInterval);
        Object.keys(soundStates).forEach(id => {
          if (soundStates[id] && soundNodes[id]?.gain && audioCtx) {
            soundNodes[id].gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 2);
          }
          soundStates[id] = false;
        });
        display!.textContent = 'Таймер завершён';
      }
      timerRemaining--;
    }
    tick();
    timerInterval = setInterval(tick, 1000);
  });
});

// === SOLFEGGIO FREQUENCIES ===

const freqOscillators: Record<number, { osc: OscillatorNode; gain: GainNode; active: boolean }> = {};

function initFreqCards(): void {
  const grid = document.getElementById('freqGrid');
  if (!grid) return;
  FREQUENCIES.forEach(freq => {
    const card = document.createElement('button');
    card.id = 'freq-' + freq.hz;
    card.className = 'freq-card flex flex-col items-start p-4 rounded-xl transition-all duration-300';
    card.style.cssText = 'background: #141E28; border: 1px solid rgba(255,255,255,0.06); cursor: pointer; text-align: left;';
    card.innerHTML = `
      <p class="font-heading text-xl text-white mb-0.5">${freq.hz} <span class="text-sm font-normal text-white/40">Гц</span></p>
      <p class="text-xs font-medium mb-1" style="color:${freq.color}">${freq.name}</p>
      <p class="text-xs text-white/30 leading-snug">${freq.desc}</p>
    `;
    card.addEventListener('click', () => toggleFreq(freq.hz, card, freq.color));
    grid.appendChild(card);
  });
}

function toggleFreq(hz: number, card: HTMLElement, color: string): void {
  if (!audioCtx || !masterGainNode) return;
  if (!freqOscillators[hz]) {
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.type = 'sine';
    osc.frequency.value = hz;
    gain.gain.value = 0;
    osc.connect(gain);
    gain.connect(masterGainNode);
    osc.start();
    freqOscillators[hz] = { osc, gain, active: false };
  }
  const entry = freqOscillators[hz];
  if (entry.active) {
    entry.gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.5);
    entry.active = false;
    card.style.borderColor = 'rgba(255,255,255,0.06)';
    card.style.boxShadow = 'none';
  } else {
    entry.gain.gain.linearRampToValueAtTime(0.12, audioCtx.currentTime + 0.5);
    entry.active = true;
    card.style.borderColor = color;
    card.style.boxShadow = `0 0 16px rgba(${hexToRgb(color)},0.2)`;
  }
}

// Presets
document.querySelectorAll('.preset-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const preset = (btn as HTMLElement).dataset.preset!;
    const freqs = PRESETS[preset] || [];
    Object.entries(freqOscillators).forEach(([hz, entry]) => {
      if (entry.active && audioCtx) {
        entry.gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.3);
        entry.active = false;
        const card = document.getElementById('freq-' + hz) as HTMLElement | null;
        if (card) { card.style.borderColor = 'rgba(255,255,255,0.06)'; card.style.boxShadow = 'none'; }
      }
    });
    setTimeout(() => {
      freqs.forEach(hz => {
        const card = document.getElementById('freq-' + hz) as HTMLElement | null;
        const freqData = FREQUENCIES.find(f => f.hz === hz);
        if (card && freqData) toggleFreq(hz, card, freqData.color);
      });
    }, 400);
  });
});

// === GUIDED MEDITATIONS ===

let meditationFreqOsc: OscillatorNode | null = null;
let meditationFreqGain: GainNode | null = null;
let meditationTimeout: ReturnType<typeof setTimeout> | null = null;
let currentScreenIndex = 0;
let currentMeditation: typeof MEDITATIONS[0] | null = null;

function initMeditationList(): void {
  const list = document.getElementById('meditationList');
  if (!list) return;
  MEDITATIONS.forEach(med => {
    const card = document.createElement('div');
    card.className = 'p-5 rounded-2xl flex items-center justify-between gap-4';
    card.style.cssText = 'background: #141E28; border: 1px solid rgba(255,255,255,0.06);';
    card.innerHTML = `
      <div>
        <p class="font-heading text-base text-white mb-1">${med.title}</p>
        <p class="text-xs text-white/40 mb-2">${med.desc}</p>
        <div class="flex items-center gap-2">
          <span class="text-xs px-2 py-0.5 rounded-full text-white/50" style="background:rgba(255,255,255,0.06);">${med.duration}</span>
          <span class="text-xs px-2 py-0.5 rounded-full" style="background:rgba(201,168,76,0.1);color:#C9A84C;">${med.freq} Гц</span>
          <a href="${med.tagLink}" class="text-xs text-white/30 hover:text-white/60 transition-colors">${med.tag} →</a>
        </div>
      </div>
      <button class="start-meditation flex-shrink-0 px-5 py-2.5 rounded-full text-sm font-medium transition-all hover:opacity-90" style="background:var(--color-accent);color:var(--color-deep);" data-med-id="${med.id}">
        Начать
      </button>
    `;
    card.querySelector('button')?.addEventListener('click', () => startMeditation(med));
    list.appendChild(card);
  });
}

function startMeditation(med: typeof MEDITATIONS[0]): void {
  if (!audioCtx || !masterGainNode) return;
  currentMeditation = med;
  currentScreenIndex = 0;

  if (meditationFreqOsc) {
    try { meditationFreqOsc.stop(); } catch (_) {}
  }
  meditationFreqOsc = audioCtx.createOscillator();
  meditationFreqGain = audioCtx.createGain();
  meditationFreqOsc.type = 'sine';
  meditationFreqOsc.frequency.value = med.freq;
  meditationFreqGain.gain.value = 0;
  meditationFreqOsc.connect(meditationFreqGain);
  meditationFreqGain.connect(masterGainNode);
  meditationFreqOsc.start();
  meditationFreqGain.gain.linearRampToValueAtTime(0.12, audioCtx.currentTime + 1);

  const player = document.getElementById('meditationPlayer');
  if (player) {
    player.style.display = 'flex';
    player.addEventListener('click', advanceScreen);
  }
  showScreen(0);
}

function showScreen(index: number): void {
  if (!currentMeditation) return;
  const screens = currentMeditation.screens;
  const textEl = document.getElementById('meditationTextBlock') as HTMLElement | null;
  const progressEl = document.getElementById('meditationProgress') as HTMLElement | null;
  const barEl = document.getElementById('meditationProgressBar') as HTMLElement | null;
  if (!textEl || !progressEl || !barEl) return;

  textEl.style.opacity = '0';
  textEl.style.transition = 'opacity 1.5s ease';

  setTimeout(() => {
    if (index >= screens.length) {
      textEl.textContent = 'Практика завершена';
      textEl.style.opacity = '1';
      progressEl.textContent = '';
      barEl.style.width = '100%';
      if (meditationFreqGain && audioCtx) {
        meditationFreqGain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 2);
      }
      return;
    }
    textEl.textContent = screens[index];
    textEl.style.opacity = '1';
    progressEl.textContent = `${index + 1} / ${screens.length}`;
    barEl.style.width = `${((index + 1) / screens.length) * 100}%`;
  }, 300);

  if (meditationTimeout) clearTimeout(meditationTimeout);
  if (index < screens.length) {
    meditationTimeout = setTimeout(() => {
      currentScreenIndex++;
      showScreen(currentScreenIndex);
    }, 5000);
  }
}

function advanceScreen(e: Event): void {
  const target = e.target as HTMLElement;
  if (target.id === 'closeMeditation' || target.closest('#closeMeditation')) return;
  if (!currentMeditation) return;
  if (meditationTimeout) clearTimeout(meditationTimeout);
  currentScreenIndex++;
  if (currentScreenIndex > currentMeditation.screens.length) return;
  showScreen(currentScreenIndex);
}

document.getElementById('closeMeditation')?.addEventListener('click', () => {
  const player = document.getElementById('meditationPlayer');
  if (player) {
    player.style.display = 'none';
    player.removeEventListener('click', advanceScreen);
  }
  if (meditationTimeout) clearTimeout(meditationTimeout);
  if (meditationFreqGain && audioCtx) {
    meditationFreqGain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 1);
  }
  currentMeditation = null;
});

// === BREATHING ===

const PATTERNS: Record<string, [number, number, number]> = {
  relax: [4, 4, 6],
  balance: [4, 4, 4],
  calm: [4, 7, 8],
};

let breathePattern: [number, number, number] = PATTERNS.relax;
let breathePhase: 'inhale' | 'hold' | 'exhale' = 'inhale';
let breatheCycleCount = 0;
let breatheMaxCycles = 0;
let breathePhaseTimeout: ReturnType<typeof setTimeout> | null = null;
let breatheOsc: OscillatorNode | null = null;
let breatheOscGain: GainNode | null = null;

document.querySelectorAll('.breathe-pattern-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const patternKey = (btn as HTMLElement).dataset.pattern!;
    breathePattern = PATTERNS[patternKey] || PATTERNS.relax;
    document.querySelectorAll('.breathe-pattern-btn').forEach(b => {
      (b as HTMLElement).style.borderColor = 'rgba(255,255,255,0.2)';
      (b as HTMLElement).style.color = 'rgba(255,255,255,0.6)';
    });
    (btn as HTMLElement).style.borderColor = '#C9A84C';
    (btn as HTMLElement).style.color = '#C9A84C';
  });
});

document.querySelectorAll('.breathe-duration').forEach(btn => {
  btn.addEventListener('click', () => {
    const m = parseInt((btn as HTMLElement).dataset.minutes!);
    const totalSeconds = m * 60;
    const cycleDuration = breathePattern[0] + breathePattern[1] + breathePattern[2];
    breatheMaxCycles = Math.floor(totalSeconds / cycleDuration);
    document.querySelectorAll('.breathe-duration').forEach(b => {
      (b as HTMLElement).style.borderColor = 'rgba(255,255,255,0.1)';
      (b as HTMLElement).style.color = 'rgba(255,255,255,0.5)';
    });
    (btn as HTMLElement).style.borderColor = '#C9A84C';
    (btn as HTMLElement).style.color = '#C9A84C';
  });
});

function startBreathing(): void {
  breatheCycleCount = 0;
  breathePhase = 'inhale';
  const startBtn = document.getElementById('breatheStart');
  const stopBtn = document.getElementById('breatheStop');
  if (startBtn) startBtn.classList.add('hidden');
  if (stopBtn) stopBtn.classList.remove('hidden');
  if (audioCtx && masterGainNode) {
    breatheOsc = audioCtx.createOscillator();
    breatheOscGain = audioCtx.createGain();
    breatheOsc.type = 'sine';
    breatheOsc.frequency.value = 180;
    breatheOscGain.gain.value = 0.04;
    breatheOsc.connect(breatheOscGain);
    breatheOscGain.connect(masterGainNode);
    breatheOsc.start();
  }
  runBreathPhase();
}

function runBreathPhase(): void {
  const circle = document.getElementById('breatheCircle') as HTMLElement | null;
  const text = document.getElementById('breatheText') as HTMLElement | null;
  const info = document.getElementById('breatheCycleInfo') as HTMLElement | null;
  if (!circle || !text || !info) return;

  if (breathePhase === 'inhale') {
    const dur = breathePattern[0];
    text.textContent = 'Вдох';
    circle.style.transition = `width ${dur}s ease-in-out, height ${dur}s ease-in-out, box-shadow ${dur}s ease-in-out`;
    circle.style.width = '180px';
    circle.style.height = '180px';
    circle.style.boxShadow = '0 0 40px rgba(201,168,76,0.35)';
    if (breatheOsc && audioCtx) breatheOsc.frequency.linearRampToValueAtTime(220, audioCtx.currentTime + dur);
    breathePhaseTimeout = setTimeout(() => { breathePhase = 'hold'; runBreathPhase(); }, dur * 1000);
  } else if (breathePhase === 'hold') {
    const dur = breathePattern[1];
    text.textContent = 'Пауза';
    breathePhaseTimeout = setTimeout(() => { breathePhase = 'exhale'; runBreathPhase(); }, dur * 1000);
  } else {
    const dur = breathePattern[2];
    text.textContent = 'Выдох';
    circle.style.transition = `width ${dur}s ease-in-out, height ${dur}s ease-in-out, box-shadow ${dur}s ease-in-out`;
    circle.style.width = '100px';
    circle.style.height = '100px';
    circle.style.boxShadow = '0 0 10px rgba(201,168,76,0.1)';
    if (breatheOsc && audioCtx) breatheOsc.frequency.linearRampToValueAtTime(160, audioCtx.currentTime + dur);
    breatheCycleCount++;
    const maxLabel = breatheMaxCycles > 0 ? ` из ${breatheMaxCycles}` : '';
    info.textContent = `Цикл ${breatheCycleCount}${maxLabel}`;
    if (breatheMaxCycles > 0 && breatheCycleCount >= breatheMaxCycles) {
      breathePhaseTimeout = setTimeout(stopBreathing, dur * 1000);
      return;
    }
    breathePhaseTimeout = setTimeout(() => { breathePhase = 'inhale'; runBreathPhase(); }, dur * 1000);
  }
}

function stopBreathing(): void {
  if (breathePhaseTimeout) clearTimeout(breathePhaseTimeout);
  const startBtn = document.getElementById('breatheStart');
  const stopBtn = document.getElementById('breatheStop');
  const textEl = document.getElementById('breatheText') as HTMLElement | null;
  const infoEl = document.getElementById('breatheCycleInfo') as HTMLElement | null;
  const circle = document.getElementById('breatheCircle') as HTMLElement | null;
  if (startBtn) startBtn.classList.remove('hidden');
  if (stopBtn) stopBtn.classList.add('hidden');
  if (textEl) textEl.textContent = '—';
  if (infoEl) infoEl.textContent = 'Нажмите «Начать», чтобы начать';
  if (circle) {
    circle.style.width = '120px';
    circle.style.height = '120px';
    circle.style.boxShadow = '0 0 20px rgba(201,168,76,0.2)';
  }
  if (breatheOsc && breatheOscGain && audioCtx) {
    breatheOscGain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.5);
    const oscRef = breatheOsc;
    setTimeout(() => { try { oscRef.stop(); } catch (_) {} }, 600);
    breatheOsc = null;
  }
}

document.getElementById('breatheStart')?.addEventListener('click', startBreathing);
document.getElementById('breatheStop')?.addEventListener('click', stopBreathing);

// Cleanup on page leave
window.addEventListener('beforeunload', () => {
  if (audioCtx) audioCtx.close();
});
</script>
