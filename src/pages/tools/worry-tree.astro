---
import ToolLayout from '@/layouts/ToolLayout.astro';
---

<ToolLayout title="Дерево тревоги">
  <div class="max-w-[580px] mx-auto">

    <div class="mb-10">
      <p class="s-label">CBT · Дерево решений</p>
      <h1 class="font-heading text-[clamp(2rem,5vw,2.8rem)] font-normal leading-[1.15] text-[var(--color-deep)] tracking-[-0.03em] mb-3">
        Дерево тревоги
      </h1>
      <p class="text-[var(--color-text-mid)] font-light leading-relaxed">
        Один вопрос за раз — и тревога становится понятнее.
      </p>
    </div>

    <!-- Input -->
    <div id="s0">
      <label class="block text-sm font-medium text-[var(--color-text)] mb-2">О чём вы тревожитесь?</label>
      <textarea
        id="worryInput"
        placeholder="Напишите, что вас беспокоит..."
        class="w-full min-h-[120px] p-5 rounded-2xl border border-[var(--color-border)] bg-white font-body text-base text-[var(--color-text)] leading-relaxed resize-none outline-none focus:border-[var(--color-primary)] transition-colors duration-300 font-light mb-4"
        style="box-shadow:inset 0 1px 0 rgba(255,255,255,0.5);"
      ></textarea>
      <button id="startBtn" class="btn-primary">
        <span>Разобраться</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>

    <!-- Tree flow -->
    <div id="treeFlow" style="display:none;">
      <!-- Growing SVG tree -->
      <div class="flex justify-center mb-8">
        <svg id="treeSvg" viewBox="0 0 200 160" width="200" height="160">
          <!-- Trunk -->
          <line x1="100" y1="155" x2="100" y2="110" stroke="rgba(27,77,92,0.3)" stroke-width="3" stroke-linecap="round"/>
          <!-- Branch 1 (step 1) -->
          <line id="b1" x1="100" y1="110" x2="60" y2="80" stroke="rgba(27,77,92,0)" stroke-width="2" stroke-linecap="round" style="transition:stroke 0.6s;"/>
          <line id="b2" x1="100" y1="110" x2="140" y2="80" stroke="rgba(27,77,92,0)" stroke-width="2" stroke-linecap="round" style="transition:stroke 0.6s;"/>
          <!-- Branch 2 (step 2) -->
          <line id="b3" x1="60" y1="80" x2="40" y2="55" stroke="rgba(27,77,92,0)" stroke-width="1.5" stroke-linecap="round" style="transition:stroke 0.6s;"/>
          <line id="b4" x1="60" y1="80" x2="75" y2="52" stroke="rgba(27,77,92,0)" stroke-width="1.5" stroke-linecap="round" style="transition:stroke 0.6s;"/>
          <!-- Leaves -->
          <circle id="l1" cx="40" cy="50" r="10" fill="rgba(42,122,145,0)" style="transition:fill 0.6s;"/>
          <circle id="l2" cx="75" cy="47" r="10" fill="rgba(42,122,145,0)" style="transition:fill 0.6s;"/>
          <circle id="l3" cx="140" cy="75" r="12" fill="rgba(42,122,145,0)" style="transition:fill 0.6s;"/>
          <!-- Worry tag -->
          <text id="worryTag" x="100" y="148" text-anchor="middle" font-size="7" fill="rgba(27,77,92,0.5)" font-family="DM Sans, sans-serif"></text>
        </svg>
      </div>

      <!-- Question card (slides) -->
      <div id="questionWrap" class="overflow-hidden">
        <div id="questionCard" class="p-8 rounded-2xl border border-[var(--color-border)] bg-white transition-all duration-400" style="box-shadow:inset 0 1px 0 rgba(255,255,255,0.5);">
          <p class="text-[0.65rem] tracking-[0.1em] uppercase font-semibold text-[var(--color-accent)] mb-3" id="qLabel"></p>
          <p class="font-heading text-xl text-[var(--color-deep)] leading-[1.5] mb-6" id="qText"></p>
          <div id="qActions" class="flex gap-3 flex-wrap"></div>
        </div>
      </div>
    </div>

    <!-- Result card -->
    <div id="resultSection" style="display:none;">
      <div id="resultCard" class="p-8 rounded-2xl border-2 mb-6 transition-all duration-500" style="opacity:0;transform:translateY(16px);">
        <p class="text-[0.65rem] tracking-[0.1em] uppercase font-semibold mb-3" id="rLabel"></p>
        <p class="font-heading text-2xl text-[var(--color-deep)] leading-[1.4] mb-4" id="rTitle"></p>
        <p class="text-[var(--color-text-mid)] font-light leading-relaxed text-sm mb-5" id="rText"></p>
        <div id="rInput" style="display:none;" class="mt-2">
          <input
            id="actionInput"
            type="text"
            class="w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-white font-body text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-primary)] transition-colors duration-300 mb-3"
            style="box-shadow:inset 0 1px 0 rgba(255,255,255,0.5);"
          />
          <p id="rConfirm" class="text-sm font-medium text-[var(--color-primary)]" style="display:none;"></p>
        </div>
      </div>

      <div class="p-6 rounded-2xl mb-6" style="background:linear-gradient(135deg,rgba(27,77,92,0.06),rgba(201,168,76,0.04));border:1px solid rgba(27,77,92,0.12);">
        <div class="flex items-start gap-4">
          <img src="/images/alexandra-confident.png" alt="Александра" class="w-12 h-12 rounded-full object-cover flex-shrink-0" style="box-shadow:0 2px 8px rgba(0,0,0,0.12);" />
          <div>
            <p class="font-heading text-base text-[var(--color-deep)] mb-1">Инструменты помогают. Но иногда нужен человек.</p>
            <p class="text-sm text-[var(--color-text-mid)] font-light mb-4">Александра здесь — когда будете готовы.</p>
            <a href="/lp/israel#pricing" class="btn-primary" style="display:inline-flex;"><span>Записаться бесплатно</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="margin-left:6px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
          </div>
        </div>
      </div>

      <button id="restartBtn" class="btn-ghost text-sm">← Новая тревога</button>
    </div>

  </div>
</ToolLayout>

<script>
  function show(el: HTMLElement) { el.style.display = ''; }
  function hide(el: HTMLElement) { el.style.display = 'none'; }
  function animateIn(el: HTMLElement) {
    el.style.opacity = '0'; el.style.transform = 'translateY(16px)';
    requestAnimationFrame(() => {
      el.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
      el.style.opacity = '1'; el.style.transform = 'translateY(0)';
    });
  }

  const s0 = document.getElementById('s0')!;
  const treeFlow = document.getElementById('treeFlow')!;
  const resultSection = document.getElementById('resultSection')!;
  const qLabel = document.getElementById('qLabel')!;
  const qText = document.getElementById('qText')!;
  const qActions = document.getElementById('qActions')!;
  const worryTag = document.getElementById('worryTag')!;
  const resultCard = document.getElementById('resultCard')!;
  const rLabel = document.getElementById('rLabel')!;
  const rTitle = document.getElementById('rTitle')!;
  const rText = document.getElementById('rText')!;
  const rInput = document.getElementById('rInput')!;
  const actionInput = document.getElementById('actionInput') as HTMLInputElement;
  const rConfirm = document.getElementById('rConfirm')!;

  function growBranch(ids: string[], color: string) {
    ids.forEach(id => {
      const el = document.getElementById(id)!;
      if (el.tagName === 'line') (el as SVGLineElement).style.stroke = color;
      if (el.tagName === 'circle') (el as SVGCircleElement).style.fill = color;
    });
  }

  function showQuestion(label: string, text: string, actions: { label: string; cb: () => void; primary?: boolean }[]) {
    const card = document.getElementById('questionCard')!;
    card.style.opacity = '0'; card.style.transform = 'translateX(20px)';
    qLabel.textContent = label;
    qText.textContent = text;
    qActions.innerHTML = '';
    actions.forEach(a => {
      const btn = document.createElement('button');
      btn.className = a.primary ? 'btn-primary flex-1 justify-center' : 'btn-ghost flex-1 justify-center border border-[var(--color-border)]';
      btn.innerHTML = `<span>${a.label}</span>`;
      btn.addEventListener('click', a.cb);
      qActions.appendChild(btn);
    });
    requestAnimationFrame(() => {
      card.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
      card.style.opacity = '1'; card.style.transform = 'translateX(0)';
    });
  }

  function showResult(label: string, labelColor: string, borderColor: string, title: string, text: string, inputPlaceholder?: string, confirmMsg?: string) {
    hide(treeFlow);
    show(resultSection);
    rLabel.textContent = label; rLabel.style.color = labelColor;
    resultCard.style.borderColor = borderColor;
    rTitle.textContent = title;
    rText.textContent = text;

    if (inputPlaceholder) {
      show(rInput);
      actionInput.placeholder = inputPlaceholder;
      actionInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && actionInput.value.trim()) {
          show(rConfirm);
          rConfirm.textContent = confirmMsg || '';
        }
      });
    } else {
      hide(rInput);
    }
    animateIn(resultCard);
  }

  document.getElementById('startBtn')!.addEventListener('click', () => {
    const text = (document.getElementById('worryInput') as HTMLTextAreaElement).value.trim();
    if (!text) return;
    hide(s0);
    show(treeFlow);

    const short = text.length > 24 ? text.slice(0, 22) + '…' : text;
    worryTag.textContent = short;
    growBranch(['b1', 'b2'], 'rgba(27,77,92,0.35)');

    showQuestion('Вопрос 1', 'Можете ли вы повлиять на то, чего вы боитесь?', [
      { label: 'Да', primary: true, cb: () => onQ1Yes() },
      { label: 'Нет', cb: () => onQ1No() },
    ]);
  });

  function onQ1Yes() {
    growBranch(['b3', 'b4'], 'rgba(42,122,145,0.5)');
    showQuestion('Вопрос 2', 'Можете ли вы сделать что-то прямо сейчас?', [
      { label: 'Да', primary: true, cb: () => onQ2Yes() },
      { label: 'Нет', cb: () => onQ2No() },
    ]);
  }

  function onQ1No() {
    growBranch(['l3'], 'rgba(201,168,76,0.5)');
    showResult(
      'Вне вашего контроля', '#C9A84C', 'rgba(201,168,76,0.3)',
      '«Тревожиться об этом — как платить аренду за квартиру, в которой вы не живёте.»',
      'Эта ситуация не в вашей власти. Единственное, что вы можете контролировать — ваш выбор прямо сейчас. Отпустить — это не слабость, это мудрость.'
    );
  }

  function onQ2Yes() {
    growBranch(['l1'], 'rgba(42,122,145,0.7)');
    showResult(
      'Время действовать', 'rgba(42,122,145,0.9)', 'rgba(42,122,145,0.3)',
      'Запишите один шаг.',
      'Тревога уменьшается, когда мы действуем. Один конкретный шаг лучше десяти мыслей.',
      'Один шаг, который я сделаю сегодня...',
      '✓ Отлично. Сделайте это. Тревога любит бездействие — лишите её его.'
    );
  }

  function onQ2No() {
    growBranch(['l2'], 'rgba(42,122,145,0.4)');
    showResult(
      'Запланируйте', 'rgba(27,77,92,0.8)', 'rgba(27,77,92,0.2)',
      'Когда именно вы это сделаете?',
      'Нельзя сейчас — значит, запишите конкретный момент. Мозг успокаивается, когда есть план. До этого момента — отпустите.',
      'Когда именно: дата и время...',
      '✓ Записано. Теперь мозг знает, что есть план — можно выдохнуть.'
    );
  }

  document.getElementById('restartBtn')!.addEventListener('click', () => {
    (document.getElementById('worryInput') as HTMLTextAreaElement).value = '';
    actionInput.value = '';
    hide(rConfirm as HTMLElement);
    ['b1','b2','b3','b4'].forEach(id => {
      (document.getElementById(id) as SVGLineElement).style.stroke = 'rgba(27,77,92,0)';
    });
    ['l1','l2','l3'].forEach(id => {
      (document.getElementById(id) as SVGCircleElement).style.fill = 'rgba(42,122,145,0)';
    });
    worryTag.textContent = '';
    hide(resultSection); show(s0);
  });
</script>
