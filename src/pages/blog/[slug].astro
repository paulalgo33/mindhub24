---
import MainLayout from '@/layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = new Date(post.data.date).toLocaleDateString('ru-RU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<MainLayout
  title={`${post.data.title} — MindHub24`}
  description={post.data.excerpt}
>

<!-- Hero -->
<section class="pt-[120px] pb-10 px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-cream)]">
  <div class="max-w-[720px] mx-auto">
    <!-- Back link -->
    <a href="/blog/" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-light)] hover:text-[var(--color-primary)] transition-colors mb-8 no-underline">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Все статьи
    </a>

    <!-- Category + date -->
    <div class="flex items-center gap-3 mb-5">
      <span class="text-[0.65rem] tracking-[0.1em] uppercase bg-[rgba(27,77,92,0.07)] text-[var(--color-primary)] py-1 px-2.5 rounded-full font-semibold">{post.data.category}</span>
      <span class="text-sm text-[var(--color-text-light)]">{formattedDate}</span>
    </div>

    <!-- Title -->
    <h1 class="font-heading text-[clamp(1.9rem,4vw,2.9rem)] font-normal leading-[1.2] text-[var(--color-deep)] tracking-[-0.02em] mb-5" data-reveal>
      {post.data.title}
    </h1>

    <!-- Excerpt -->
    <p class="text-lg text-[var(--color-text-mid)] font-light leading-relaxed mb-6" data-reveal>
      {post.data.excerpt}
    </p>

    <!-- Author -->
    <div class="flex items-center gap-3 pb-8 border-b border-[var(--color-border)]" data-reveal>
      <img src="/images/alexandra-hero.jpeg" alt="Александра" class="w-10 h-10 rounded-full object-cover" style="object-position:center 15%;" loading="eager" />
      <div>
        <p class="text-sm font-medium text-[var(--color-deep)]">{post.data.author}</p>
        <p class="text-xs text-[var(--color-text-light)]">Психолог-консультант · MindHub24</p>
      </div>
    </div>
  </div>
</section>

<!-- Cover image -->
{post.data.coverImage && (
  <div class="px-[clamp(1.5rem,4vw,3rem)] pb-10 bg-[var(--color-cream)]">
    <div class="max-w-[720px] mx-auto">
      <img
        src={post.data.coverImage}
        alt={post.data.title}
        class="w-full h-56 md:h-72 object-cover rounded-2xl"
        loading="eager"
      />
    </div>
  </div>
)}

<!-- Article body -->
<article class="px-[clamp(1.5rem,4vw,3rem)] pb-[var(--spacing-section)] bg-[var(--color-cream)]">
  <div class="max-w-[720px] mx-auto prose prose-lg">
    <Content />
  </div>
</article>

<!-- Alexandra CTA card -->
<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-warm)]">
  <div class="max-w-[680px] mx-auto">
    <div class="bg-white rounded-3xl border border-[var(--color-border)] p-8 md:p-10 card-glass flex flex-col md:flex-row gap-8 items-center" data-reveal>
      <img src="/images/alexandra-hero.jpeg" alt="Александра — психолог-консультант" class="w-20 h-20 rounded-full object-cover flex-shrink-0" style="object-position:center 15%;" loading="lazy" />
      <div class="flex-1 text-center md:text-left">
        <p class="text-xs tracking-[0.1em] uppercase text-[var(--color-accent)] font-semibold mb-2">Александра · Психолог-консультант</p>
        <h2 class="font-heading text-xl font-normal text-[var(--color-deep)] mb-2">Хотите поговорить об этом лично?</h2>
        <p class="text-sm text-[var(--color-text-mid)] font-light mb-5">Первая встреча — бесплатно. 15 минут онлайн, без обязательств.</p>
        <a href="/book/" class="btn-primary" style="font-size:0.875rem;padding:0.75rem 1.75rem;">
          <span>Записаться бесплатно</span>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Back to blog -->
<section class="py-8 px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-cream)] text-center border-t border-[var(--color-border)]">
  <a href="/blog/" class="btn-ghost">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
    Все статьи блога
  </a>
</section>

</MainLayout>

<style>
  /* Prose styles for blog article body */
  .prose {
    color: var(--color-text-mid);
    font-size: 1.0625rem;
    line-height: 1.85;
    font-weight: 300;
  }
  .prose h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 2.5vw, 1.75rem);
    font-weight: 400;
    color: var(--color-deep);
    margin: 2.5rem 0 1rem;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }
  .prose h3 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-deep);
    margin: 2rem 0 0.75rem;
  }
  .prose p {
    margin: 0 0 1.5rem;
  }
  .prose strong {
    font-weight: 600;
    color: var(--color-deep);
  }
  .prose em {
    font-style: italic;
    color: var(--color-text-mid);
  }
  .prose ul, .prose ol {
    margin: 0 0 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prose li {
    padding-left: 0.25rem;
  }
  .prose ul li::marker {
    color: var(--color-accent);
  }
  .prose a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose a:hover {
    color: var(--color-primary-light);
  }
  .prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }
  .prose blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text-mid);
  }
  .prose code {
    background: rgba(27,77,92,0.06);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }
</style>
