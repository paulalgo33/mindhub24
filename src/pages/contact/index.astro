---
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout
  title="Контакты — MindHub24"
  description="Свяжитесь с MindHub24. Email, Telegram или запись на встречу."
>

<section class="pt-[120px] pb-16 px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-cream)]">
  <div class="max-w-[720px] mx-auto">
    <p class="s-label" data-reveal>Связаться</p>
    <h1 class="s-title" data-reveal>Контакты</h1>
    <p class="s-subtitle" data-reveal>Напишите нам — ответим в течение нескольких часов.</p>
  </div>
</section>

<section class="pb-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-cream)]">
  <div class="max-w-[720px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
    {[
      {
        icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg>`,
        title: 'Telegram',
        value: '@mindhub24',
        href: 'https://t.me/mindhub24',
        desc: 'Самый быстрый способ связаться',
      },
      {
        icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 8l10 7 10-7"/></svg>`,
        title: 'Email',
        value: 'hello@mindhub24.com',
        href: 'mailto:hello@mindhub24.com',
        desc: 'Для вопросов и предложений',
      },
    ].map((item) => (
      <a href={item.href} class="p-8 bg-white rounded-2xl border border-[var(--color-border)] card-glass card-lift no-underline flex flex-col gap-4" data-reveal target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener' : undefined}>
        <div class="w-12 h-12 rounded-xl flex items-center justify-center text-[var(--color-primary)]" style="background:rgba(27,77,92,0.07);" set:html={item.icon} />
        <div>
          <p class="font-heading text-lg font-semibold text-[var(--color-deep)] mb-1">{item.title}</p>
          <p class="text-[var(--color-primary)] font-medium mb-1">{item.value}</p>
          <p class="text-sm text-[var(--color-text-light)] font-light">{item.desc}</p>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- Contact form placeholder -->
<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-warm)]">
  <div class="max-w-[600px] mx-auto">
    <p class="s-label" data-reveal>Форма обратной связи</p>
    <h2 class="s-title" data-reveal>Написать нам</h2>
    <div class="flex flex-col gap-4 mt-8" data-reveal>
      <div>
        <label class="text-xs tracking-[0.08em] uppercase text-[var(--color-text-light)] font-semibold block mb-2">Имя</label>
        <input type="text" placeholder="Ваше имя" class="w-full px-5 py-3.5 rounded-2xl border border-[var(--color-border)] bg-white text-sm outline-none focus:border-[var(--color-primary)] transition-colors" />
      </div>
      <div>
        <label class="text-xs tracking-[0.08em] uppercase text-[var(--color-text-light)] font-semibold block mb-2">Email</label>
        <input type="email" placeholder="ваш@email.com" class="w-full px-5 py-3.5 rounded-2xl border border-[var(--color-border)] bg-white text-sm outline-none focus:border-[var(--color-primary)] transition-colors" />
      </div>
      <div>
        <label class="text-xs tracking-[0.08em] uppercase text-[var(--color-text-light)] font-semibold block mb-2">Сообщение</label>
        <textarea rows="5" placeholder="Что вы хотите написать..." class="w-full px-5 py-3.5 rounded-2xl border border-[var(--color-border)] bg-white text-sm outline-none focus:border-[var(--color-primary)] transition-colors resize-none"></textarea>
      </div>
      <button class="btn-primary self-start"><span>Отправить</span></button>
      <p class="text-xs text-[var(--color-text-light)]">Форма в разработке — пока напишите нам напрямую в Telegram или на email.</p>
    </div>
  </div>
</section>

<!-- Crisis link -->
<section class="py-16 px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-cream)] text-center">
  <div class="max-w-[540px] mx-auto">
    <p class="text-[var(--color-text-mid)] font-light mb-3" data-reveal>Вам нужна срочная помощь?</p>
    <a href="/crisis/" class="btn-ghost text-sm" data-reveal>Кризисные ресурсы →</a>
  </div>
</section>

</MainLayout>
