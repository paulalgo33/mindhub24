---
/**
 * WOW Factor 13 — Grounding Audio Library "Звуки Опоры"
 * Free access. 5 recordings for specific moments.
 * Each 2-3 min. Soft CTA at end.
 * Deepens parasocial bond with Alexandra's voice.
 */
import LandingLayout from '@/layouts/LandingLayout.astro';

const recordings = [
  {
    icon: '🫁',
    title: 'Если у вас паническая атака прямо сейчас',
    desc: 'Дыхание + техника заземления 5-4-3-2-1',
    duration: '2 мин',
    color: 'rgba(212, 114, 106, 0.08)',
    border: 'rgba(212, 114, 106, 0.15)',
  },
  {
    icon: '🌙',
    title: 'Если вы не можете заснуть',
    desc: 'Сканирование тела, прогрессивная релаксация',
    duration: '3 мин',
    color: 'rgba(27, 77, 92, 0.06)',
    border: 'rgba(27, 77, 92, 0.12)',
  },
  {
    icon: '💬',
    title: 'Если вы только что поссорились',
    desc: 'Техника эмоционального охлаждения',
    duration: '2 мин',
    color: 'rgba(201, 168, 76, 0.06)',
    border: 'rgba(201, 168, 76, 0.12)',
  },
  {
    icon: '🏠',
    title: 'Если вы тоскуете по дому',
    desc: 'Визуализация + самосострадание',
    duration: '3 мин',
    color: 'rgba(74, 124, 89, 0.06)',
    border: 'rgba(74, 124, 89, 0.12)',
  },
  {
    icon: '🧠',
    title: 'Если вам кажется, что вы не справляетесь',
    desc: 'Когнитивная дефузия: мысль — это мысль, не факт',
    duration: '2 мин',
    color: 'rgba(27, 77, 92, 0.06)',
    border: 'rgba(27, 77, 92, 0.12)',
  },
];
---

<LandingLayout
  title="MindHub24 — Звуки Опоры"
  description="Бесплатная аудиотека: упражнения заземления для тревоги, бессонницы, тоски по дому. Голос Александры."
  lang="ru"
>

<nav class="fixed top-0 left-0 right-0 z-100 px-[clamp(1.5rem,4vw,3rem)]" style="background:rgba(250,247,242,0.9);backdrop-filter:blur(20px)">
  <div class="max-w-[1400px] mx-auto flex items-center justify-between h-16">
    <a href="/lp/israel" class="font-heading text-xl font-semibold text-[var(--color-deep)] no-underline">
      MindHub24<span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] inline-block ml-0.5 mb-0.5"></span>
    </a>
    <a href="/lp/israel#pricing" class="text-sm bg-[var(--color-deep)] text-white px-5 py-2 rounded-full no-underline font-medium">Записаться</a>
  </div>
</nav>

<main class="pt-28 pb-20 px-[clamp(1.5rem,4vw,3rem)]">
  <div class="max-w-[700px] mx-auto">

    <div class="text-center mb-14">
      <p class="s-label" data-reveal>Бесплатно</p>
      <h1 class="font-heading text-[clamp(2rem,4vw,3rem)] font-normal text-[var(--color-deep)] mb-4 leading-tight" data-reveal="d1">
        Звуки Опоры
      </h1>
      <p class="text-lg text-[var(--color-text-mid)] font-light leading-relaxed max-w-[500px] mx-auto" data-reveal="d2">
        Короткие аудио-упражнения для трудных моментов. Голос Александры. Без регистрации.
      </p>
    </div>

    <div class="flex flex-col gap-5">
      {recordings.map((rec, i) => (
        <div
          class="p-6 rounded-2xl border transition-all duration-500 cursor-pointer hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(0,0,0,0.06)] group"
          style={`background:${rec.color};border-color:${rec.border}`}
          data-reveal={`d${Math.min(i + 1, 5)}`}
        >
          <div class="flex items-center gap-5">
            <div class="w-14 h-14 rounded-full bg-white flex items-center justify-center shrink-0 shadow-sm text-xl group-hover:scale-105 transition-transform">
              {rec.icon}
            </div>
            <div class="flex-1">
              <h3 class="font-heading text-base font-semibold mb-1">{rec.title}</h3>
              <p class="text-sm text-[var(--color-text-mid)] font-light">{rec.desc}</p>
            </div>
            <div class="text-right shrink-0">
              <div class="text-xs text-[var(--color-text-light)] font-medium mb-1">{rec.duration}</div>
              <div class="w-10 h-10 rounded-full bg-[var(--color-deep)] flex items-center justify-center opacity-80 group-hover:opacity-100 transition-opacity">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><polygon points="6 3 20 12 6 21 6 3" /></svg>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-14">
      <p class="text-base text-[var(--color-text-mid)] font-light italic mb-6" data-reveal>
        «Если вы хотите работать глубже — я здесь.»
      </p>
      <a href="/lp/israel#pricing" class="btn-primary" data-reveal="d1">
        <span>Записаться на бесплатную встречу</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <p class="text-sm text-[var(--color-text-light)] mt-3 font-light">20 минут · Бесплатно</p>
    </div>

  </div>
</main>

</LandingLayout>
