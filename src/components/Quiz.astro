---
interface Props {
  label: string;
  title: string;
  subtitle: string;
  cta: string;
  fine: string;
  questions: { q: string; opts: string[] }[];
  result: string;
  resultCta: string;
}
const { label, title, subtitle, cta, fine, questions, result, resultCta } = Astro.props;
---

<section class="py-[var(--spacing-section)] px-[clamp(1.5rem,4vw,3rem)] bg-[var(--color-cream)]" id="quizSection">
  <div class="max-w-[700px] mx-auto bg-white rounded-[28px] p-[clamp(2.5rem,5vw,4rem)] border border-[var(--color-border)] text-center shadow-[0_20px_60px_rgba(0,0,0,0.03)]" data-reveal>
    <p class="s-label">{label}</p>
    <h2 class="s-title">{title}</h2>
    <p class="text-lg text-[var(--color-text-mid)] font-light leading-relaxed mb-0 max-w-[400px] mx-auto">{subtitle}</p>
    <button
      class="btn-primary mt-6 mx-auto"
      id="quizOpenBtn"
    >
      <span>{cta}</span>
    </button>
    <p class="text-xs text-[var(--color-text-light)] mt-3 font-light">{fine}</p>
  </div>
</section>

<!-- Quiz modal -->
<div class="fixed inset-0 z-300 hidden items-center justify-center p-8 bg-black/50 backdrop-blur-[20px]" id="quizModal">
  <div class="bg-[var(--color-cream)] rounded-[28px] p-12 max-w-[520px] w-full relative max-h-[90vh] overflow-y-auto animate-[modalSlideIn_0.5s_cubic-bezier(0.16,1,0.3,1)]" id="quizBox">
    <button class="absolute top-5 right-5 w-10 h-10 border-none bg-[var(--color-warm)] rounded-full cursor-pointer flex items-center justify-center text-lg text-[var(--color-text-mid)] transition-all duration-200 hover:bg-[var(--color-sand)] hover:text-[var(--color-text)]" id="quizCloseBtn">✕</button>
    <div id="quizContent"></div>
  </div>
</div>

<style>
  @keyframes modalSlideIn {
    from { opacity: 0; transform: translateY(30px) scale(0.96); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  [data-night="true"] #quizBox { background: var(--color-cream); }
</style>

<script define:vars={{ questions, result, resultCta }}>
  let currentQ = 0;

  document.getElementById('quizOpenBtn')?.addEventListener('click', () => {
    currentQ = 0;
    const modal = document.getElementById('quizModal');
    if (modal) { modal.style.display = 'flex'; }
    renderQuestion();
  });

  document.getElementById('quizCloseBtn')?.addEventListener('click', closeQuiz);
  document.getElementById('quizModal')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('quizModal')) closeQuiz();
  });

  function closeQuiz() {
    const modal = document.getElementById('quizModal');
    if (modal) modal.style.display = 'none';
  }

  function renderQuestion() {
    const container = document.getElementById('quizContent');
    if (!container) return;
    const q = questions[currentQ];
    const dots = questions.map((_, i) =>
      `<div style="flex:1;height:3px;border-radius:3px;background:${i < currentQ ? 'var(--color-accent)' : i === currentQ ? 'var(--color-primary)' : 'var(--color-sand)'};transition:all 0.5s cubic-bezier(0.16,1,0.3,1)"></div>`
    ).join('');
    const opts = q.opts.map((o, i) =>
      `<div class="quiz-opt" data-idx="${i}" style="padding:1rem 1.5rem;border:1px solid var(--color-border);border-radius:14px;cursor:pointer;transition:all 0.3s ease;font-size:0.95rem;background:white">${o}</div>`
    ).join('');
    container.innerHTML = `
      <div style="display:flex;gap:8px;margin-bottom:2.5rem">${dots}</div>
      <h3 style="font-family:var(--font-heading);font-size:1.35rem;font-weight:500;margin-bottom:2rem;line-height:1.4">${q.q}</h3>
      <div style="display:flex;flex-direction:column;gap:0.75rem">${opts}</div>
    `;
    container.querySelectorAll('.quiz-opt').forEach(opt => {
      opt.addEventListener('click', () => {
        opt.style.borderColor = 'var(--color-primary)';
        opt.style.background = 'rgba(27,77,92,0.06)';
        setTimeout(() => { currentQ++; currentQ < questions.length ? renderQuestion() : showResult(); }, 350);
      });
    });
  }

  function showResult() {
    const container = document.getElementById('quizContent');
    if (!container) return;
    container.innerHTML = `
      <div style="text-align:center;padding:1rem 0">
        <p style="font-family:var(--font-heading);font-size:1.2rem;line-height:1.8;font-style:italic;margin-bottom:2rem">${result}</p>
        <a href="#pricing" class="btn-primary" onclick="document.getElementById('quizModal').style.display='none'" style="display:inline-flex;align-items:center;gap:10px;background:var(--color-deep);color:white;border:none;padding:1rem 2.2rem;border-radius:100px;font-size:0.95rem;font-weight:500;text-decoration:none">
          <span>${resultCta}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    `;
  }
</script>
