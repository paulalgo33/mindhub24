---
interface Props {
  class?: string;
}
---
<div class={`alexandra-cta p-6 rounded-2xl ${Astro.props.class || ''}`} style="background:linear-gradient(135deg,rgba(27,77,92,0.06) 0%,rgba(201,168,76,0.04) 100%);border:1px solid rgba(27,77,92,0.12);">
  <div class="flex items-start gap-4">
    <img
      src="/images/alexandra-hero.jpeg"
      alt="Александра"
      class="w-12 h-12 rounded-full object-cover flex-shrink-0"
      style="box-shadow:0 2px 8px rgba(0,0,0,0.12);"
    />
    <div class="flex-1">
      <p class="font-heading text-base text-[var(--color-deep)] mb-1 leading-snug">
        Инструменты помогают. Но иногда нужен человек.
      </p>
      <p class="text-sm text-[var(--color-text-mid)] font-light mb-4">
        Александра здесь — когда будете готовы.
      </p>
      <a
        href="/lp/israel#pricing"
        class="btn-primary"
        style="display:inline-flex;"
      >
        <span>Записаться бесплатно</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</div>
