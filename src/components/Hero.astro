---
import type { Translations } from '@/i18n/ru';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section class="min-h-screen flex items-center relative overflow-hidden px-[clamp(1.5rem,4vw,3rem)]">
  <!-- Animated mesh gradient background -->
  <div style="position:absolute;width:60vw;height:60vw;border-radius:50%;top:-10%;right:-5%;background:radial-gradient(circle,rgba(27,77,92,0.07),transparent 70%);pointer-events:none;animation:meshDriftA 22s ease-in-out infinite;"></div>
  <div style="position:absolute;width:50vw;height:50vw;border-radius:50%;bottom:0;left:-8%;background:radial-gradient(circle,rgba(201,168,76,0.05),transparent 70%);pointer-events:none;animation:meshDriftB 28s ease-in-out infinite;"></div>

  <div class="max-w-[1400px] mx-auto w-full grid grid-cols-1 lg:grid-cols-[1fr_0.85fr] gap-[clamp(2rem,6vw,6rem)] items-center relative z-[2] pt-30 pb-20 lg:pt-32 lg:pb-20">
    <!-- Content -->
    <div class="max-w-[640px]">
      <div id="heroEyebrow" class="inline-flex items-center gap-2 mb-8">
        <span class="w-2 h-2 rounded-full bg-[var(--color-accent)]" style="animation:breathe 3s ease-in-out infinite;"></span>
        <span class="text-[0.78rem] tracking-[0.14em] uppercase text-[var(--color-text-mid)] font-medium">{t.hero.eyebrow}</span>
      </div>

      <!-- Day hero -->
      <div id="dayHero">
        <h1 id="heroH1Day" class="font-heading text-[clamp(3rem,7vw,5rem)] font-normal leading-[1.08] text-[var(--color-deep)] tracking-[-0.04em] mb-7">
          <span class="block overflow-hidden"><span class="hero-h1-line block">{t.hero.title}</span></span>
          <span class="block overflow-hidden"><em class="hero-h1-line block italic text-gradient">{t.hero.titleEm}</em></span>
        </h1>
        <p id="heroDesc" class="text-lg text-[var(--color-text-mid)] leading-[1.85] font-light mb-10 max-w-[480px]">
          {t.hero.desc}
        </p>
      </div>

      <!-- Night hero -->
      <div id="nightHero" style="display:none">
        <h1 id="heroH1Night" class="font-heading text-[clamp(3rem,7vw,5rem)] font-normal leading-[1.08] text-[var(--color-deep)] tracking-[-0.04em] mb-7">
          <span class="block overflow-hidden"><span class="hero-h1-line block">{t.heroNight.title}</span></span>
        </h1>
        <p id="heroDescNight" class="text-lg text-[var(--color-text-mid)] leading-[1.85] font-light mb-6 max-w-[480px]">
          {t.heroNight.desc}
        </p>
        <div class="mt-6 p-7 bg-[rgba(42,122,145,0.08)] border border-[rgba(42,122,145,0.15)] rounded-2xl text-base text-[var(--color-text-mid)] leading-[1.9]">
          {t.heroNight.breathing}
        </div>
      </div>

      <div id="heroButtons" class="flex items-center gap-5 flex-wrap">
        <a href="#pricing" class="btn-primary">
          <span>{t.hero.cta}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
        </a>
        <button class="btn-ghost" onclick="document.getElementById('audioSection')?.scrollIntoView({behavior:'smooth'})">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21" /></svg>
          {t.hero.ghost}
        </button>
      </div>

      <p class="text-sm text-[var(--color-text-light)] mt-5 font-light" data-reveal>
        {t.hero.micro}
      </p>
    </div>

    <!-- Hero image -->
    <div id="heroImageWrapper" class="relative hide-mobile">
      <div class="rounded-3xl overflow-hidden shadow-[0_40px_80px_rgba(0,0,0,0.1),0_0_0_1px_rgba(0,0,0,0.04)] aspect-[3/4] max-h-[620px]">
        <img
          id="heroImg"
          src="/images/alexandra-desk-warm.png"
          alt="MindHub24 — Александра"
          class="w-full h-full object-cover"
          loading="eager"
          style="will-change:transform;"
        />
      </div>
      <!-- Floating badge -->
      <div id="heroFloat" class="absolute bottom-6 left-6 right-6 bg-white/90 backdrop-blur-[20px] rounded-2xl py-5 px-6 flex items-center gap-4 border border-white/50 shadow-[0_8px_32px_rgba(0,0,0,0.07)]">
        <div class="w-11 h-11 rounded-xl bg-[var(--color-deep)] flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
        </div>
        <div>
          <div class="text-sm font-medium text-[var(--color-text)]">{t.hero.floatTitle}</div>
          <div class="text-xs text-[var(--color-text-mid)] font-light mt-0.5">{t.hero.floatSub}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes breathe {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }
  @keyframes meshDriftA {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-3%, 4%) scale(1.06); }
    66% { transform: translate(3%, -3%) scale(0.96); }
  }
  @keyframes meshDriftB {
    0%, 100% { transform: translate(0, 0) scale(1); }
    40% { transform: translate(4%, -5%) scale(1.08); }
    70% { transform: translate(-4%, 3%) scale(0.94); }
  }
  [data-night="true"] #heroFloat {
    background: rgba(22, 27, 34, 0.9);
    border-color: rgba(255, 255, 255, 0.08);
  }
</style>
