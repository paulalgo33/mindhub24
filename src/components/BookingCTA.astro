---
interface Props {
  quote: string;
}
const { quote } = Astro.props;
---

<section class="py-16 md:py-20 px-4" style="background: linear-gradient(180deg, var(--color-warm) 0%, #F5EDE0 50%, var(--color-cream) 100%);">
  <div class="max-w-xl mx-auto text-center">

    <!-- Rotating quote -->
    <p class="font-heading text-xl md:text-2xl text-[var(--color-deep)] leading-relaxed mb-8 italic">
      "{quote}"
    </p>

    <!-- Alexandra photo + name -->
    <div class="flex items-center justify-center gap-3 mb-6">
      <img src="/images/alexandra-hero.jpeg" alt="Александра"
        class="w-14 h-14 rounded-full object-cover border-2 border-white shadow-lg" style="object-position:center 15%;" />
      <div class="text-left">
        <p class="font-heading text-base text-[var(--color-deep)]">Александра</p>
        <p class="text-sm text-[var(--color-text-mid)]">Психолог-консультант</p>
      </div>
    </div>

    <!-- Main CTA button -->
    <a href="/book/"
      class="inline-flex items-center gap-2 px-8 py-4 text-lg font-medium text-white rounded-full shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
      style="background: linear-gradient(135deg, #1B4D5C 0%, #2A6E82 100%);">
      Записаться на бесплатный онлайн-звонок
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>

    <!-- Micro-copy -->
    <p class="mt-4 text-sm text-[var(--color-text-mid)]">
      15 минут · Бесплатно · Онлайн · Конфиденциально
    </p>

    <p class="mt-2 text-xs text-[var(--color-text-light)]">
      Ответим в течение 24 часов
    </p>

  </div>
</section>
