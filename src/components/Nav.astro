---
interface Props {
  cta: string;
  lang: string;
}
const { cta } = Astro.props;
---

<nav
  class="fixed top-0 left-0 right-0 z-100 px-[clamp(1.5rem,4vw,3rem)] transition-all duration-600"
  id="mainNav"
  style="will-change: transform;"
>
  <div class="max-w-[1400px] mx-auto flex items-center justify-between h-20">
    <a href="#" class="font-heading text-2xl font-semibold text-[var(--color-deep)] no-underline tracking-[-0.03em] flex items-baseline gap-0.5">
      MindHub24<span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] inline-block ml-0.5 mb-0.5"></span>
    </a>
    <div class="flex items-center gap-4">
      <button
        id="navCta"
        class="nav-cta bg-[var(--color-deep)] text-white border-none px-6 py-2.5 rounded-full font-body text-sm font-medium cursor-pointer transition-all duration-400 tracking-[0.01em] hover:bg-[var(--color-primary)] hover:shadow-[0_4px_24px_rgba(15,46,56,0.25)] hover:-translate-y-px relative overflow-hidden"
        onclick="document.getElementById('pricing')?.scrollIntoView({behavior:'smooth'})"
      >
        {cta}
      </button>
    </div>
  </div>
</nav>

<style>
  nav::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(250, 247, 242, 0.85);
    backdrop-filter: blur(30px) saturate(1.8);
    -webkit-backdrop-filter: blur(30px) saturate(1.8);
    opacity: 0;
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    border-bottom: 1px solid transparent;
    z-index: -1;
  }
  nav.scrolled::after {
    opacity: 1;
    border-bottom-color: var(--color-border);
  }
  [data-night="true"] nav::after {
    background: rgba(11, 15, 19, 0.88);
  }

  /* Nav CTA shimmer */
  #navCta::after {
    content: '';
    position: absolute;
    top: 0;
    left: -80%;
    width: 50%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
    pointer-events: none;
    transition: none;
  }
  #navCta.shimmer-run::after {
    animation: ctaShimmer 0.55s ease forwards;
  }
  @keyframes ctaShimmer {
    0%   { left: -80%; }
    100% { left: 160%; }
  }

  /* Heartbeat pulse every 8s */
  @keyframes navPulse {
    0%   { box-shadow: 0 0 0 0 rgba(15,46,56,0.4); }
    40%  { box-shadow: 0 0 0 10px rgba(15,46,56,0); }
    100% { box-shadow: 0 0 0 0 rgba(15,46,56,0); }
  }
  #navCta.pulse-run {
    animation: navPulse 0.8s ease-out forwards;
  }
</style>

<script>
  const navCta = document.getElementById('navCta');

  function runPulse() {
    if (!navCta) return;
    navCta.classList.remove('pulse-run', 'shimmer-run');
    void navCta.offsetWidth; // reflow
    navCta.classList.add('pulse-run', 'shimmer-run');
    setTimeout(() => {
      navCta?.classList.remove('shimmer-run');
    }, 600);
  }

  // Fire after 3s on load, then every 8s
  setTimeout(() => {
    runPulse();
    setInterval(runPulse, 8000);
  }, 3000);
</script>
